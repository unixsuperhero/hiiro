#!/usr/bin/env ruby

require 'hiiro'
require 'shellwords'
require 'tempfile'
require 'pathname'

opts = Hiiro::Options.setup {
  flag(:danger, short: :d, default: false)
  flag(:horizontal, short: :h, default: false)
  flag(:percent, short: :p, default: false)
  flag(:bottom, short: :b, default: false)
  flag(:left, short: :l, default: false)
  flag(:ignore, short: :i, default: false)
  option(:size, short: :s, default: nil)
}

tool_opts = Hiiro::Options.setup {
  flag(:full, short: :f, default: false, desc: 'fulltext search - full grep file or dir')
  flag(:absolute, short: :a, default: false, desc: 'print absolute path to matching tool file')
  flag(:verbose, short: :v, default: false, desc: 'display claude dirs in stderr')
  flag(:veryverbose, short: :V, default: false, desc: 'display all stderr messages')
}

def tool_file(path, skill: false)
  return path unless skill

  path / 'SKILL.md'
end

def display_tool_path(path, bname: nil, opts:, skill: false)
  target = tool_file(path, skill: skill)
  return target if opts.absolute
  return path.basename if skill

  target.basename(bname.to_s)
end

def glob_path(glob, bname=nil, opts:, skill: false)
  filters = opts.args
  fulltext = opts.full
  bname ||= ''
  filters ||= []
  filters = ['.*'] if filters.empty?

  claude_paths.map { |path|
    [
      path.split&.first,
      path.glob(glob),
    ]
  }.each do |path, fs|
    next if fs.empty?

    $stderr.puts if opts.verbose || opts.veryverbose
    $stderr.puts "PATH: #{path}" if opts.verbose || opts.veryverbose

    re_s = filters.join(?|)
    re = Regexp.new(re_s)
    fs.each do |f|
      more_args = f.file? ? [] : ['-r']
      cmd = ['egrep', *more_args, '-m1', re_s, f.to_s]
      kwcmd = { out: File.open('/dev/null', 'w') }
      base_f = f.basename(bname)
      display_f = display_tool_path(f, bname: bname, opts: opts, skill: skill)

      matches = 
        if fulltext
          system(*cmd, **kwcmd)
        else
          base_f.to_s.match?(re)
        end

      if matches
        puts display_f
      else
        $stderr.puts "SKIPPING #{base_f}" if opts.veryverbose
      end
    end
  end
end

# Like glob_path but returns an array of full Pathname objects instead of printing.
# skill: true → resolve matched directories to <dir>/SKILL.md
def collect_files(glob, bname=nil, opts:, skill: false)
  filters = opts.args
  filters = ['.*'] if filters.empty?
  re_s    = filters.join(?|)
  re      = Regexp.new(re_s)

  claude_paths.flat_map { |path| path.glob(glob) }.filter_map do |f|
    base_f = f.basename(bname.to_s)
    next unless base_f.to_s.match?(re)
    target = tool_file(f, skill: skill)
    target if target.exist?
  end
end

def permission_flag(opts)
  opts.danger ? '--dangerously-skip-permissions' : '--allow-dangerously-skip-permissions'
end

def start_command(opts)
  shell = ENV['SHELL'] || 'zsh'
  escaped_args = opts.args.map(&:shellescape)
  ['claude', permission_flag(opts), *escaped_args, ";exec #{shell}"].join(' ')
end

# Fire-and-forget: runs claude -p, no exec $SHELL so the window closes when done
def fire_command(opts)
  escaped_args = opts.args.map(&:shellescape)
  ['claude', '-p', permission_flag(opts), *escaped_args].join(' ')
end

# Walk from Dir.pwd up through parent directories, stopping before Dir.home.
# Returns an array of existing .claude directories, closest-first.
def claude_paths
  Pathname(Dir.pwd)
    .ascend
    .map { |p| p / '.claude' }
    .select(&:exist?)
end

Hiiro.run(*ARGV, plugins: [Pins]) {
  add_subcmd(:split) { |*args|
    opts = opts.parse(args)

    size = opts.size || '40'
    size += '%' if opts.percent
    cmd = opts.ignore ? fire_command(opts) : start_command(opts)

    tmux_client.split_window(horizontal: !opts.horizontal, size: size, command: cmd)
  }

  add_subcmd(:vsplit) { |*args|
    opts = opts.parse(args)

    size = opts.size
    size += '%' if size && opts.percent
    cmd = opts.ignore ? fire_command(opts) : start_command(opts)

    tmux_client.vsplit_window(size: size, command: cmd)
    tmux_client.swap_current_pane(0, keep_active: true) if opts.left
  }

  add_subcmd(:hsplit) { |*args|
    opts = opts.parse(args)

    size = opts.size
    size += '%' if size && opts.percent
    cmd = opts.ignore ? fire_command(opts) : start_command(opts)

    tmux_client.hsplit_window(size: size, command: cmd)
    tmux_client.swap_current_pane(0, keep_active: true) unless opts.bottom
  }

  add_subcmd(:window) { |*args|
    opts = opts.parse(args)
    cmd = opts.ignore ? fire_command(opts) : start_command(opts)
    tmux_client.new_window(command: cmd)
  }

add_subcmd(:env) { |*args|
    ap ENV
  }

  add_subcmd(:inline) { |*args|
    if args.empty? && !$stdin.tty?
      prompt = $stdin.read.strip
    elsif args.any?
      prompt = args.join(' ')
    else
      tmpfile = Tempfile.new(['claude-inline-', '.md'])
      tmpfile.close
      edit_files(tmpfile.path)
      prompt = File.read(tmpfile.path).strip
      tmpfile.unlink
      if prompt.empty?
        puts "Aborted (empty file)"
        next
      end
    end

    IO.popen(['claude', '-p'], 'w') { |io| io.write(prompt) }
  }

  add_subcmd(:all) { |*args|
    opts = tool_opts.parse(args)
    glob_path('agents/*.md', '.md', opts: opts)
    glob_path('commands/*.md', '.md', opts: opts)
    glob_path('skills/*/', opts: opts, skill: true)
  }

  add_subcmd(:agents) { |*args|
    opts = tool_opts.parse(args)
    glob_path('agents/*.md', '.md', opts: opts)
  }

  add_subcmd(:commands) { |*args|
    opts = tool_opts.parse(args)
    glob_path('commands/*.md', '.md', opts: opts)
  }

  add_subcmd(:skills) { |*args|
    opts = tool_opts.parse(args)
    glob_path('skills/*/', opts: opts, skill: true)
  }

  add_subcmd(:vim) { |*args|
    opts  = tool_opts.parse(args)
    files = collect_files('agents/*.md',  '.md', opts: opts) +
            collect_files('commands/*.md', '.md', opts: opts) +
            collect_files('skills/*/',           opts: opts, skill: true)

    if files.empty?
      puts "No matching files found."
      next
    end

    edit_files(*files.map(&:to_s))
  }

  add_subcmd(:new) { |*args|
    tmpfile = Tempfile.new(['claude-new-', '.md'])
    tmpfile.close
    edit_files(tmpfile.path)
    prompt = File.read(tmpfile.path).strip
    tmpfile.unlink
    if prompt.empty?
      puts "Aborted (empty file)"
      next
    end
    exec('claude', '--allow-dangerously-skip-permissions', prompt)
  }

  add_subcmd(:loop) { |*args|
    separator = "-" * 72
    history = []

    loop do
      tmpfile = Tempfile.new(['claude-loop-', '.md'])

      if history.any?
        lines = []
        history.each_with_index do |(prev_prompt, response), i|
          lines << "# Prompt #{i + 1} (old - do not edit)"
          prev_prompt.lines.each { |l| lines << "> #{l.chomp}" }
          lines << ""
          lines << "## Response #{i + 1}"
          lines << response
          lines << ""
        end
        lines << separator
        lines << "# Put your new prompt below this line"
        lines << ""
        tmpfile.write(lines.join("\n"))
      end

      tmpfile.close
      edit_files(tmpfile.path)
      content = File.read(tmpfile.path).strip
      tmpfile.unlink

      if content.empty?
        puts "Done."
        break
      end

      # Extract only the new prompt (below the separator)
      if content.include?(separator)
        new_prompt = content.split(separator, 2).last.strip
        # Strip the instruction line if present
        new_prompt = new_prompt.sub(/\A# Put your new prompt below this line\n*/, '').strip
      else
        new_prompt = content.strip
      end

      if new_prompt.empty?
        puts "Done."
        break
      end

      # Build the full prompt with context for claude
      full_prompt = ""
      if history.any?
        history.each_with_index do |(prev_prompt, response), i|
          full_prompt << "--- Previous prompt #{i + 1} ---\n#{prev_prompt}\n\n"
          full_prompt << "--- Response #{i + 1} ---\n#{response}\n\n"
        end
        full_prompt << "--- New prompt ---\n"
      end
      full_prompt << new_prompt

      puts "\nSending to claude...\n\n"
      response = IO.popen(['claude', '-p'], 'r+') { |io|
        io.write(full_prompt)
        io.close_write
        io.read
      }

      puts response
      history << [new_prompt, response]
    end
  }
}
