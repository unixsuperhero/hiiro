#!/usr/bin/env ruby

require "hiiro"
require "time"
require "fileutils"
require "yaml"
require "json"
require "tempfile"

class PinnedPRManager
  def pr_repo(pr)
    pr.repo || Hiiro::Git::Pr.repo_from_url(pr.url)
  end

  def initialize
    ensure_file
  end

  def ensure_file
    dir = File.dirname(Hiiro::Git::Pr::PINNED_FILE)
    FileUtils.mkdir_p(dir) unless Dir.exist?(dir)
    File.write(Hiiro::Git::Pr::PINNED_FILE, [].to_yaml) unless File.exist?(Hiiro::Git::Pr::PINNED_FILE)
  end

  def load_pinned
    ensure_file
    prs = Hiiro::Git::Pr.pinned_prs
    if prs.any? { |p| p.slot.nil? }
      next_slot = prs.map { |p| p.slot.to_i }.max.to_i
      prs.each do |p|
        next if p.slot
        next_slot += 1
        p.slot = next_slot
      end
      save_pinned(prs)
    end
    prs
  end

  def save_pinned(prs)
    ensure_file
    File.write(Hiiro::Git::Pr::PINNED_FILE, prs.map(&:to_pinned_h).to_yaml)
  end

  def pin(pr)
    pr.repo ||= Hiiro::Git::Pr.repo_from_url(pr.url)

    pinned = load_pinned
    existing = pinned.find { |p|
      p.number == pr.number && pr_repo(p) == pr_repo(pr)
    }

    if existing
      existing.title           = pr.title           unless pr.title.nil?
      existing.state           = pr.state           unless pr.state.nil?
      existing.url             = pr.url             unless pr.url.nil?
      existing.head_branch     = pr.head_branch     unless pr.head_branch.nil?
      existing.repo            = pr.repo            unless pr.repo.nil?
      existing.is_draft        = pr.is_draft        unless pr.is_draft.nil?
      existing.mergeable       = pr.mergeable       unless pr.mergeable.nil?
      existing.review_decision = pr.review_decision unless pr.review_decision.nil?
      existing.check_runs      = pr.check_runs      unless pr.check_runs.nil?
      existing.checks          = pr.checks          unless pr.checks.nil?
      existing.reviews         = pr.reviews         unless pr.reviews.nil?
      existing.task            = pr.task            unless pr.task.nil?
      existing.worktree        = pr.worktree        unless pr.worktree.nil?
      existing.tmux_session    = pr.tmux_session    unless pr.tmux_session.nil?
      existing.tags            = pr.tags            unless pr.tags.nil?
      existing.assigned        = pr.assigned        unless pr.assigned.nil?
      existing.authored        = pr.authored        unless pr.authored.nil?
      existing.updated_at      = Time.now.iso8601
    else
      pr.slot      = (pinned.map { |p| p.slot.to_i }.max.to_i) + 1
      pr.pinned_at = Time.now.iso8601
      pinned << pr
    end

    save_pinned(pinned)
    pr
  end

  def unpin(pr_number)
    pinned = load_pinned
    removed = pinned.reject! { |p| p.number.to_s == pr_number.to_s }
    save_pinned(pinned)
    removed
  end

  def pinned?(pr_number)
    load_pinned.any? { |p| p.number.to_s == pr_number.to_s }
  end

  def fetch_pr_info(pr_number, repo: nil)
    fields = 'number,title,url,headRefName,state,statusCheckRollup,reviewDecision,reviews,isDraft,mergeable'
    repo_flag = repo ? " --repo #{repo}" : ""
    output = `gh pr view #{pr_number}#{repo_flag} --json #{fields} 2>/dev/null`.strip
    return nil if output.empty?
    Hiiro::Git::Pr.from_gh_json(JSON.parse(output))
  rescue JSON::ParserError
    nil
  end

  def fetch_current_branch_pr
    fields = 'number,title,url,headRefName,state'
    output = `gh pr view --json #{fields} 2>/dev/null`.strip
    return nil if output.empty?
    Hiiro::Git::Pr.from_gh_json(JSON.parse(output))
  rescue JSON::ParserError
    nil
  end

  def fetch_my_prs
    output = `gh pr list --author @me --state open --json number,title,headRefName,url 2>/dev/null`.strip
    return [] if output.empty?
    prs = JSON.parse(output) rescue []
    prs.map { |data| Hiiro::Git::Pr.from_gh_json(data) }
  end

  def fetch_assigned_prs
    output = `gh pr list --assignee @me --state open --json number,title,headRefName,url 2>/dev/null`.strip
    return [] if output.empty?
    prs = JSON.parse(output) rescue []
    prs.map { |data| Hiiro::Git::Pr.from_gh_json(data) }
  end

  def fetch_my_and_assigned_prs
    authored_prs = fetch_my_prs
    assigned_prs = fetch_assigned_prs

    authored_numbers = authored_prs.map(&:number).to_set
    assigned_prs.each { |pr| pr.assigned = true unless authored_numbers.include?(pr.number) }
    authored_prs.each { |pr| pr.authored = true }

    (authored_prs + assigned_prs).uniq(&:number)
  end

  def needs_refresh?(pr, force: false)
    return true if force
    return true unless pr.last_checked

    last_check_time = Time.parse(pr.last_checked) rescue nil
    return true unless last_check_time

    # Refresh if last check was more than 2 minutes ago
    (Time.now - last_check_time) > 120
  end

  def code_freeze_active?
    return @code_freeze_active unless @code_freeze_active.nil?

    output = `isc codefreeze list 2>/dev/null`.strip
    return @code_freeze_active = false if output.empty?

    now = Time.now
    @code_freeze_active = output.lines.drop(1).any? do |line|
      parts = line.strip.split(/\s{2,}/)
      next false if parts.length < 2

      start_time = Time.parse(parts[0]) rescue nil
      end_time   = Time.parse(parts[1]) rescue nil
      next false unless start_time && end_time

      now >= start_time && now <= end_time
    end
  rescue
    @code_freeze_active = false
  end

  # Overrides the ISC code freeze StatusContext in a raw statusCheckRollup array
  # to reflect the actual current freeze state rather than GitHub's cached value.
  def apply_isc_code_freeze_override!(rollup, frozen)
    return unless rollup.is_a?(Array)

    rollup.each do |ctx|
      next unless ctx['__typename'] == 'StatusContext' && ctx['context'] == 'ISC code freeze'
      ctx['state'] = frozen ? 'FAILURE' : 'SUCCESS'
    end
  end


  # Accepts an array of PR records (each with 'number' and optionally 'repo'/'url'),
  # groups them by repo, and fetches in batches per repo via GraphQL.
  def batch_fetch_pr_info(prs)
    return {} if prs.empty?

    by_repo = prs.group_by { |pr| pr_repo(pr) || 'instacart/carrot' }

    result = {}
    by_repo.each do |repo_path, repo_prs|
      owner, name = repo_path.split('/', 2)
      pr_numbers = repo_prs.map(&:number)
      result.merge!(fetch_batch_for_repo(owner, name, pr_numbers))
    end
    result
  end

  private

  def fetch_batch_for_repo(owner, name, pr_numbers)
    return {} if pr_numbers.empty?

    pr_queries = pr_numbers.map.with_index do |num, idx|
      <<~GRAPHQL.strip
        pr#{idx}: pullRequest(number: #{num}) {
          number
          title
          url
          headRefName
          state
          isDraft
          mergeable
          reviewDecision
          statusCheckRollup {
            contexts(last: 100) {
              nodes {
                ... on CheckRun {
                  __typename
                  name
                  conclusion
                  status
                  detailsUrl
                }
                ... on StatusContext {
                  __typename
                  context
                  state
                  targetUrl
                }
              }
            }
          }
          reviews(last: 50) {
            nodes {
              author {
                login
              }
              state
            }
          }
        }
      GRAPHQL
    end

    query = <<~GRAPHQL
      query {
        repository(owner: "#{owner}", name: "#{name}") {
          #{pr_queries.join("\n")}
        }
      }
    GRAPHQL

    result = `gh api graphql -f query='#{query.gsub("'", "'\\''")}' 2>/dev/null`
    return {} if result.empty?

    data = JSON.parse(result)
    repo_data = data.dig('data', 'repository')
    return {} unless repo_data

    pr_info_by_key = {}
    repo_path = "#{owner}/#{name}"
    pr_numbers.each_with_index do |num, idx|
      pr_data = repo_data["pr#{idx}"]
      next unless pr_data

      pr_info_by_key[[num, repo_path]] = {
        'number' => pr_data['number'],
        'title' => pr_data['title'],
        'url' => pr_data['url'],
        'headRefName' => pr_data['headRefName'],
        'state' => pr_data['state'],
        'isDraft' => pr_data['isDraft'],
        'mergeable' => pr_data['mergeable'],
        'reviewDecision' => pr_data['reviewDecision'],
        'statusCheckRollup' => pr_data.dig('statusCheckRollup', 'contexts', 'nodes'),
        'reviews' => pr_data.dig('reviews', 'nodes') || [],
        'repo' => repo_path
      }
    end

    pr_info_by_key
  rescue JSON::ParserError, StandardError
    {}
  end

  public

  def refresh_all_status(prs, force: false)
    prs_to_refresh = prs.select { |pr| needs_refresh?(pr, force: force) }

    if prs_to_refresh.empty?
      puts "All PRs recently checked (within last 2 minutes). Use -U to force update." unless force
      return prs
    end

    # infos is keyed by [number, repo] to avoid collisions across repos
    infos = batch_fetch_pr_info(prs_to_refresh)
    frozen = code_freeze_active?

    prs_to_refresh.each do |pr|
      info = infos[[pr.number, pr_repo(pr) || 'instacart/carrot']]
      next unless info

      rollup = info['statusCheckRollup']
      apply_isc_code_freeze_override!(rollup, frozen)

      pr.state           = info['state']
      pr.title           = info['title']
      pr.check_runs      = rollup
      pr.checks          = Hiiro::Git::Pr.summarize_checks(rollup)
      pr.reviews         = Hiiro::Git::Pr.summarize_reviews(info['reviews'])
      pr.review_decision = info['reviewDecision']
      pr.is_draft        = info['isDraft']
      pr.mergeable       = info['mergeable']
      pr.last_checked    = Time.now.iso8601
    end

    prs
  end

  def refresh_status(pr, force: false)
    return pr unless needs_refresh?(pr, force: force)

    info = fetch_pr_info(pr.number, repo: pr_repo(pr))
    return pr unless info

    rollup = info.check_runs
    apply_isc_code_freeze_override!(rollup, code_freeze_active?)

    pr.state           = info.state
    pr.title           = info.title
    pr.check_runs      = rollup
    pr.checks          = Hiiro::Git::Pr.summarize_checks(rollup)
    pr.reviews         = info.reviews
    pr.review_decision = info.review_decision
    pr.is_draft        = info.is_draft
    pr.mergeable       = info.mergeable
    pr.last_checked    = Time.now.iso8601
    pr
  end

  FILTER_PREDICATES = {
    red:       ->(pr) { (c = pr.checks) && c['failed'].to_i > 0 },
    green:     ->(pr) { (c = pr.checks) && c['failed'].to_i == 0 && c['pending'].to_i == 0 && c['success'].to_i > 0 },
    conflicts: ->(pr) { pr.conflicting? },
    drafts:    ->(pr) { pr.draft? },
    pending:   ->(pr) { (c = pr.checks) && c['pending'].to_i > 0 && c['failed'].to_i == 0 },
    merged:    ->(pr) { pr.merged? },
    active:    ->(pr) { !pr.merged? && !pr.closed? },
  }.freeze

  def display_pinned(pr, idx = nil, widths: {}, oneline: false)
    slot_w  = widths[:slot]  || 1
    succ_w  = widths[:succ]  || 1
    total_w = widths[:total] || 1
    as_w    = widths[:as]    || 1
    crs_w   = widths[:crs]   || 1

    slot_num = (pr.slot || (idx ? idx + 1 : 1)).to_s
    num    = "#{slot_num.rjust(slot_w)}."
    indent = " " * (slot_w + 2)

    check_emoji, checks_count_str =
      if pr.checks
        c = pr.checks
        has_failed   = c['failed'].to_i > 0
        has_pending  = c['pending'].to_i > 0
        only_frozen  = has_failed && c['failed'].to_i == c['frozen'].to_i
        emoji = if has_failed && has_pending
          only_frozen ? "⏳❄️" : "⏳❌"
        elsif has_failed
          only_frozen ? "　❄️" : "　❌"
        elsif has_pending
          "⏳　"
        else
          "　✅"
        end
        succ  = c['success'].to_i.to_s.rjust(succ_w)
        total = c['total'].to_i.to_s.rjust(total_w)
        [emoji, "#{succ}/#{total}"]
      else
        ["", nil]
      end

    state_label = case pr.state
    when 'MERGED' then 'M'
    when 'CLOSED' then 'X'
    else pr.draft? ? 'd' : 'o'
    end

    bracket_parts = [state_label, check_emoji, checks_count_str].reject { |p| p.nil? || p.empty? }
    state_icon = "[#{bracket_parts.join(' ')}]"

    r = pr.reviews || {}
    as  = r['approved'].to_i
    crs = r['changes_requested'].to_i

    as_val  = as  > 0 ? as.to_s  : '-'
    crs_val = crs > 0 ? crs.to_s : '-'
    as_colored  = as  > 0 ? "\e[30;102m#{as_val}\e[0m"  : as_val
    crs_colored = crs > 0 ? "\e[30;103m#{crs_val}\e[0m" : crs_val
    as_pad  = " " * [as_w  - as_val.length,  0].max
    crs_pad = " " * [crs_w - crs_val.length, 0].max
    conflict_str = pr.conflicting? ? " \e[30;101mC\e[0m" : ""
    reviews_str = "#{as_pad}#{as_colored}a/#{crs_pad}#{crs_colored}cr#{conflict_str}"

    repo = pr_repo(pr)
    repo_label = (repo && repo != 'instacart/carrot') ? "[#{repo}] " : ""

    tags = Array(pr.tags)
    tags_str = tags.any? ? tags.map { |t| "\e[30;104m#{t}\e[0m" }.join(' ') : nil

    branch_str = pr.head_branch ? " \e[90m#{pr.head_branch}\e[0m" : ""
    title_str = "\e[1m#{pr.title}\e[0m"
    line1 = "#{num} ##{pr.number} #{state_icon} #{reviews_str}#{branch_str}"
    line2 = "#{indent}#{repo_label}#{title_str}"
    line3 = pr.url ? "#{indent}#{pr.url}" : nil
    line4 = tags_str ? "#{indent}#{tags_str}" : nil

    if oneline
      "#{line1} #{repo_label}#{title_str}"
    else
      [line1, line2, line3, line4].compact.join("\n")
    end
  end

  def filter_active?(opts)
    FILTER_PREDICATES.keys.any? { |f| opts.respond_to?(f) && opts.send(f) } ||
      (opts.respond_to?(:tag) && Array(opts.tag).any?)
  end

  def apply_filters(prs, opts, forced: [])
    active = FILTER_PREDICATES.keys.select { |f| opts.respond_to?(f) && opts.send(f) }
    active = (active + forced).uniq

    results = active.empty? ? prs : prs.select { |pr| active.any? { |f| FILTER_PREDICATES[f]&.call(pr) } }

    # Tags are an AND post-filter; multiple tags are OR'd among themselves
    tag_filter = Array(opts.respond_to?(:tag) ? opts.tag : nil).map(&:to_s).reject(&:empty?)
    unless tag_filter.empty?
      results = results.select { |pr| (Array(pr.tags) & tag_filter).any? }
    end

    results
  end

  def display_detailed(pr, idx = nil)
    lines = []
    num = idx ? "#{idx + 1}." : ""

    state_str = case pr.state
    when 'MERGED' then 'MERGED'
    when 'CLOSED' then 'CLOSED'
    else pr.draft? ? 'DRAFT' : 'OPEN'
    end

    repo = pr_repo(pr)
    repo_label = (repo && repo != 'instacart/carrot') ? " [#{repo}]" : ""

    lines << "#{num} ##{pr.number}#{repo_label} - #{pr.title}"
    lines << "   State: #{state_str}"
    lines << "   Branch: #{pr.head_branch}" if pr.head_branch
    lines << "   URL: #{pr.url}" if pr.url

    # Checks
    if pr.checks
      c = pr.checks
      check_status = if c['failed'] > 0
        "FAILING (#{c['success']}/#{c['total']} passed, #{c['failed']} failed)"
      elsif c['pending'] > 0
        "PENDING (#{c['success']}/#{c['total']} passed, #{c['pending']} pending)"
      else
        "PASSING (#{c['success']}/#{c['total']})"
      end
      lines << "   Checks: #{check_status}"
    else
      lines << "   Checks: (none)"
    end

    # Reviews
    if pr.reviews
      r = pr.reviews
      review_parts = []
      review_parts << "#{r['approved']} approved" if r['approved'] > 0
      review_parts << "#{r['changes_requested']} requesting changes" if r['changes_requested'] > 0
      review_parts << "#{r['commented']} commented" if r['commented'] > 0

      if review_parts.any?
        lines << "   Reviews: #{review_parts.join(', ')}"
        if r['reviewers'] && !r['reviewers'].empty?
          r['reviewers'].each do |author, state|
            icon = case state
            when 'APPROVED' then '+'
            when 'CHANGES_REQUESTED' then '-'
            else '?'
            end
            lines << "      #{icon} #{author}: #{state.downcase.gsub('_', ' ')}"
          end
        end
      else
        lines << "   Reviews: (none)"
      end
    else
      lines << "   Reviews: (not fetched)"
    end

    lines << "   Mergeable: #{pr.mergeable}" if pr.mergeable

    lines.join("\n")
  end

  def pr_yaml_lines(prs = nil)
    (prs || load_pinned).map do |pr|
      branch = pr.head_branch ? "[#{pr.head_branch}]" : "[##{pr.number}]"
      "- #{pr.number}  # #{branch} #{pr.title}"
    end
  end

  def display_check_runs(pr, indent: "   ")
    runs = pr.check_runs
    return unless runs.is_a?(Array) && runs.any?

    runs.each do |run|
      case run['__typename']
      when 'CheckRun'
        emoji = check_run_emoji(run['conclusion'], run['status'])
        name  = run['name'] || run['workflowName'] || '(unknown)'
        url   = run['detailsUrl']
      when 'StatusContext'
        emoji = status_context_emoji(run['state'])
        name  = run['context'] || '(unknown)'
        url   = run['targetUrl']
      else
        emoji = '?'
        name  = run['name'] || run['context'] || '(unknown)'
        url   = run['detailsUrl'] || run['targetUrl']
      end

      line = "#{indent}#{emoji}  #{name}"
      line += "\n#{indent}   #{url}" if url
      puts line
    end
  end

  private

  def check_run_emoji(conclusion, status)
    return "⏳" if %w[QUEUED IN_PROGRESS PENDING REQUESTED WAITING].include?(status) && conclusion.nil?
    case conclusion
    when 'SUCCESS'          then "✅"
    when 'FAILURE', 'ERROR' then "❌"
    when 'TIMED_OUT'        then "⏰"
    when 'CANCELLED'        then "🚫"
    when 'SKIPPED'          then "⏭ "
    when 'NEUTRAL'          then "⚪"
    when 'STARTUP_FAILURE'  then "💥"
    when 'ACTION_REQUIRED'  then "⚠️ "
    else                         "⏳"
    end
  end

  def status_context_emoji(state)
    case state
    when 'SUCCESS'          then "✅"
    when 'FAILURE', 'ERROR' then "❌"
    when 'PENDING'          then "⏳"
    else                         "❓"
    end
  end

  public
end

FILTER_OPTS = Proc.new {
  flag(:red,       short: 'r', desc: 'filter: failing checks')
  flag(:green,     short: 'g', desc: 'filter: passing checks')
  flag(:conflicts, short: 'c', desc: 'filter: merge conflicts')
  flag(:drafts,    short: 'd', desc: 'filter: draft PRs')
  flag(:pending,   short: 'p', desc: 'filter: pending checks')
  flag(:merged,    short: 'm', desc: 'filter: merged PRs')
  flag(:active,    short: 'o', desc: 'filter: open (non-merged) PRs')
  flag(:numbers,   short: 'n', desc: 'output PR numbers only (no #)')
  option(:tag,     short: 't', desc: 'filter by tag (OR when multiple; AND with flag filters)', multi: true)
}

Hiiro.run(*ARGV, plugins: [Pins]) do
  pinned_manager = PinnedPRManager.new

  resolve_pr = ->(ref) {
    if ref.nil?
      pinned = pinned_manager.load_pinned
      if pinned.empty?
        STDERR.puts "No tracked PRs. Use a PR number or 'h pr track' to track PRs."
        return nil
      end
      lines = pinned.each_with_index.each_with_object({}) do |(pr, idx), h|
        h[pinned_manager.display_pinned(pr, idx)] = pr.number.to_s
      end
      return fuzzyfind_from_map(lines)
    end

    if (pin_value = pins.get(ref.to_s))
      return pin_value
    end

    pinned = pinned_manager.load_pinned

    if pinned.any? { |pr| pr.number.to_s == ref.to_s }
      return ref.to_s
    end

    if ref.to_s =~ /^\d+$/ && ref.to_i > 0
      slot = ref.to_i
      by_slot = pinned.find { |p| p.slot.to_i == slot }
      return by_slot.number.to_s if by_slot
      # Fall back to 1-based index for unslotted data
      idx = slot - 1
      return pinned[idx].number.to_s if idx < pinned.length
    end

    ref.to_s
  }

  watch_block = ->(original_pr_number=nil, *watch_args) {
    watch = get_value(:watch)
    fail_fast = get_value(:fail_fast)

    pr_number = resolve_pr.call(original_pr_number)
    return unless pr_number

    base_cmd = %w[gh pr checks]
    base_cmd << '--watch' if watch
    base_cmd << '--fail-fast' if fail_fast

    command = [*base_cmd, pr_number, *watch_args]

    puts command: command, base_cmd: base_cmd, args: [pr_number, *watch_args];

    result = system(*command)

    pr_info = JSON.parse(`gh pr view #{pr_number} --json url,number,title`)
    pr_url = pr_info['url']
    pr_num = pr_info['number']
    pr_title = pr_info['title']

    if result
      system('say', 'pr good')
      system('terminal-notifier', '-title', 'PR Good', '-message', "##{pr_num}: #{pr_title}", '-open', pr_url)
    else
      system('say', 'pr bad')
      system('terminal-notifier', '-title', 'PR Bad', '-message', "##{pr_num}: #{pr_title}", '-open', pr_url)
    end
  }

  add_subcmd(:check, &watch_block)
  add_subcmd(:watch, watch: true, &watch_block)
  add_subcmd(:fwatch, watch: true, fail_fast: true, &watch_block)

  add_flag(:verbose, short: :v, desc: 'verbose output')
  add_cmd(:tst, args: [:a], opts: [:verbose]) do |*x|
    puts x: x
    puts 'test'
  end

  add_subcmd(:number) { |*args|
    stdout = `gh pr view`

    number = stdout[/number:\s*(\d+)/, 1]

    if number
      print number
    else
      puts stdout
    end
  }

  add_subcmd(:link) { |ref=nil|
    pr_number = resolve_pr.call(ref)
    next unless pr_number

    pinned = pinned_manager.load_pinned
    pr = pinned.find { |p| p.number.to_s == pr_number.to_s }

    if pr && pr.url
      print pr.url
    else
      output = `gh pr view #{pr_number} --json url 2>/dev/null`
      info = JSON.parse(output) rescue nil
      if info&.dig('url')
        print info['url']
      else
        STDERR.puts "Could not find URL for PR ##{pr_number}"
      end
    end
  }

  add_subcmd(:edit) { edit_files(__FILE__) }
  add_subcmd(:open) { |pr_number=nil|
    if pr_number.nil?
      current = pinned_manager.fetch_current_branch_pr
      if current
        pinned = pinned_manager.load_pinned
        pr = pinned.find { |p| p.number.to_s == current.number.to_s }
        url = pr&.url || current.url
        url ? system('open', url) : system('gh', 'pr', 'view', current.number.to_s, '--web')
        next
      end
    end
    pr_number = resolve_pr.call(pr_number)
    next unless pr_number
    pinned = pinned_manager.load_pinned
    pr = pinned.find { |p| p.number.to_s == pr_number.to_s }
    pr&.url ? system('open', pr.url) : system('gh', 'pr', 'view', pr_number.to_s, '--web')
  }
  add_subcmd(:view) { |pr_number=nil|
    pr_number = resolve_pr.call(pr_number)
    system('gh', 'pr', 'view', pr_number.to_s) if pr_number
  }

  add_subcmd(:select) do |*args|
    # Get my open PRs
    output = `gh pr list --author @me --state open --json number,title,headRefName 2>/dev/null`.strip

    if output.empty?
      STDERR.puts "No open PRs found"
      next
    end

    prs = (JSON.parse(output) rescue []).map { |data| Hiiro::Git::Pr.from_gh_json(data) }
    if prs.empty?
      STDERR.puts "No open PRs found"
      next
    end

    lines = prs.each_with_object({}) do |pr, h|
      display = "##{pr.number} [#{pr.head_branch}] #{pr.title}"
      h[display] = pr.number.to_s
    end

    selected = fuzzyfind_from_map(lines)
    print selected if selected
  end

  add_subcmd(:copy) do |*args|
    output = `gh pr list --author @me --state open --json number,title,headRefName 2>/dev/null`.strip

    if output.empty?
      STDERR.puts "No open PRs found"
      next
    end

    prs = (JSON.parse(output) rescue []).map { |data| Hiiro::Git::Pr.from_gh_json(data) }
    if prs.empty?
      STDERR.puts "No open PRs found"
      next
    end

    lines = prs.each_with_object({}) do |pr, h|
      display = "##{pr.number} [#{pr.head_branch}] #{pr.title}"
      h[display] = pr.number.to_s
    end

    selected = fuzzyfind_from_map(lines)

    if selected
      Hiiro::Shell.pipe(selected, 'pbcopy')
      puts "Copied PR ##{selected} to clipboard"
    end
  end

  # === PR Tracking ===

  add_subcmd(:track) do |ref = nil|
    pr_info = nil

    case ref
    when nil, '-'
      # Try current branch's PR first, fall back to fuzzy select
      pr_info = pinned_manager.fetch_current_branch_pr

      unless pr_info
        my_prs = pinned_manager.fetch_my_prs
        if my_prs.empty?
          puts "No open PRs found"
          next
        end

        lines = my_prs.each_with_object({}) do |pr, h|
          display = "##{pr.number} [#{pr.head_branch}] #{pr.title}"
          h[display] = pr
        end

        pr_info = fuzzyfind_from_map(lines)
        unless pr_info
          puts "No PR selected"
          next
        end
      end
    when /^\d+$/
      # Track by PR number
      pr_info = pinned_manager.fetch_pr_info(ref)
      unless pr_info
        puts "PR ##{ref} not found"
        next
      end
    else
      puts "Usage: h pr track [-|PR_NUMBER]"
      puts "  -       Track current branch's PR"
      puts "  <num>   Track PR by number"
      puts "  (none)  Select from your open PRs"
      next
    end

    if pinned_manager.pinned?(pr_info.number)
      puts "Already tracking ##{pr_info.number}"
      next
    end

    env = Environment.current rescue nil
    if env
      task = env.task
      pr_info.task         = task.name      if task
      pr_info.worktree     = task.tree_name if task&.tree_name
      pr_info.tmux_session = env.session&.name
    end

    pinned_manager.pin(pr_info)
    puts "Now tracking ##{pr_info.number}: #{pr_info.title}"
    puts
    run_subcmd(:update)
  end

  add_subcmd(:ls) do |*ls_args|
    opts = Hiiro::Options.parse(ls_args) {
      flag(:update,  short: 'u', desc: 'update status before listing')
      flag(:oneline, short: '1', desc: 'one line per PR')
      flag(:checks,  short: 'C', desc: 'show individual check run details')
      instance_eval(&FILTER_OPTS)
    }

    if opts.help
      puts opts.help_text
      exit 1
    end

    pinned = pinned_manager.load_pinned
    next puts "No tracked PRs" if pinned.empty?

    if opts.update
      puts "Updating status for #{pinned.length} PR(s)..."
      pinned_manager.refresh_all_status(pinned, force: true)
      pinned_manager.save_pinned(pinned)
      puts
    end

    results = pinned_manager.apply_filters(pinned, opts)

    if results.empty?
      puts pinned_manager.filter_active?(opts) ? "No PRs match filters." : "No tracked PRs."
      next
    end

    if opts.numbers
      results.each { |pr| puts pr.number }
    else
      slot_w  = results.map { |pr| (pr.slot || 1).to_s.length }.max
      succ_w  = results.filter_map { |pr| pr.checks&.dig('success')&.to_i&.to_s&.length }.max || 1
      total_w = results.filter_map { |pr| pr.checks&.dig('total')&.to_i&.to_s&.length }.max || 1
      as_w    = results.map { |pr| [pr.reviews&.dig('approved').to_i.to_s.length, 1].max }.max
      crs_w   = results.map { |pr| [pr.reviews&.dig('changes_requested').to_i.to_s.length, 1].max }.max
      widths  = { slot: slot_w, succ: succ_w, total: total_w, as: as_w, crs: crs_w }
      results.each_with_index do |pr, idx|
        puts pinned_manager.display_pinned(pr, idx, widths: widths, oneline: opts.oneline)
        pinned_manager.display_check_runs(pr) if opts.checks
      end
      last_checked = pinned.filter_map(&:last_checked).max
      puts "---"
      puts "Last updated: #{last_checked || 'never'}"
    end
  end

  add_subcmd(:status) do |*status_args|
    opts = Hiiro::Options.parse(status_args, &FILTER_OPTS)

    pinned = pinned_manager.load_pinned
    next puts "No tracked PRs" if pinned.empty?

    results = pinned_manager.apply_filters(pinned, opts)

    if results.empty?
      puts pinned_manager.filter_active?(opts) ? "No PRs match filters." : "No tracked PRs."
      next
    end

    if opts.numbers
      results.each { |pr| puts pr.number }
    else
      results.each_with_index do |pr, idx|
        puts pinned_manager.display_detailed(pr, idx)
        puts
      end
      last_checked = pinned.filter_map(&:last_checked).max
      puts "---"
      puts "Last updated: #{last_checked || 'never'}"
    end
  end

  add_subcmd(:update) do |*update_args|
    pinned = pinned_manager.load_pinned

    if pinned.empty?
      puts "No tracked PRs to update"
      next
    end

    force = update_args.include?('-U') || update_args.include?('--force-update')

    puts "Updating status for #{pinned.length} PR(s)..."
    pinned_manager.refresh_all_status(pinned, force: force)
    pinned_manager.save_pinned(pinned)
    puts "Done."

    puts
    run_subcmd(:ls)

  end

  add_subcmd(:green) do |*green_args|
    opts = Hiiro::Options.parse(green_args, &FILTER_OPTS)
    pinned = pinned_manager.load_pinned
    results = pinned_manager.apply_filters(pinned, opts, forced: [:green])

    if results.empty?
      puts "No PRs match."
      next
    end

    if opts.numbers
      results.each { |pr| puts pr.number }
    else
      results.each_with_index { |pr, i| puts pinned_manager.display_pinned(pr, i) }
    end
  end

  add_subcmd(:red) do |*red_args|
    opts = Hiiro::Options.parse(red_args, &FILTER_OPTS)
    pinned = pinned_manager.load_pinned
    results = pinned_manager.apply_filters(pinned, opts, forced: [:red])

    if results.empty?
      puts "No PRs match."
      next
    end

    if opts.numbers
      results.each { |pr| puts pr.number }
    else
      results.each_with_index { |pr, i| puts pinned_manager.display_pinned(pr, i) }
    end
  end

  add_subcmd(:old) do |*old_args|
    opts = Hiiro::Options.parse(old_args, &FILTER_OPTS)
    pinned = pinned_manager.load_pinned
    results = pinned_manager.apply_filters(pinned, opts, forced: [:merged])

    if results.empty?
      puts "No PRs match."
      next
    end

    if opts.numbers
      results.each { |pr| puts pr.number }
    else
      results.each_with_index { |pr, i| puts pinned_manager.display_pinned(pr, i) }
    end
  end

  add_subcmd(:prune) do |*args|
    pinned = pinned_manager.load_pinned

    if pinned.empty?
      puts "No tracked PRs"
      next
    end

    merged_or_closed = pinned.select { |pr| pr.merged? || pr.closed? }

    if merged_or_closed.empty?
      puts "No merged or closed PRs to prune"
      next
    end

    puts "Pruning #{merged_or_closed.length} merged/closed PR(s):"
    puts

    merged_or_closed.each do |pr|
      puts "  ##{pr.number}: #{pr.title} [#{pr.state}]"
      pinned_manager.unpin(pr.number)
    end

    puts
    puts "Done. #{pinned_manager.load_pinned.length} PR(s) still tracked."
  end

  add_subcmd(:draft) do |*draft_args|
    opts = Hiiro::Options.parse(draft_args, &FILTER_OPTS)
    pinned = pinned_manager.load_pinned
    results = pinned_manager.apply_filters(pinned, opts, forced: [:drafts])

    if results.empty?
      puts "No PRs match."
      next
    end

    if opts.numbers
      results.each { |pr| puts pr.number }
    else
      results.each_with_index { |pr, i| puts pinned_manager.display_pinned(pr, i) }
    end
  end

  add_subcmd(:assigned) do
    prs = pinned_manager.fetch_assigned_prs

    if prs.empty?
      puts "No PRs assigned to you"
      next
    end

    pinned_numbers = pinned_manager.load_pinned.map(&:number).to_set
    puts "PRs assigned to you (#{prs.count}):"
    puts
    prs.each_with_index do |pr, i|
      tracked = pinned_numbers.include?(pr.number) ? ' [tracked]' : ''
      puts "  #{i + 1}. ##{pr.number} #{pr.title} [#{pr.head_branch}]#{tracked}"
    end
  end

  add_subcmd(:created) do
    prs = pinned_manager.fetch_my_prs

    if prs.empty?
      puts "No open PRs created by you"
      next
    end

    pinned_numbers = pinned_manager.load_pinned.map(&:number).to_set
    puts "PRs created by you (#{prs.count}):"
    puts
    prs.each_with_index do |pr, i|
      tracked = pinned_numbers.include?(pr.number) ? ' [tracked]' : ''
      puts "  #{i + 1}. ##{pr.number} #{pr.title} [#{pr.head_branch}]#{tracked}"
    end
  end

  add_subcmd(:missing) do
    my_prs = pinned_manager.fetch_my_and_assigned_prs
    pinned_numbers = pinned_manager.load_pinned.map(&:number)
    missing = my_prs.reject { |pr| pinned_numbers.include?(pr.number) }

    if missing.empty?
      puts "All your PRs are tracked"
      next
    end

    puts "Untracked PRs (#{missing.count}):"
    puts
    missing.each do |pr|
      relationship = pr.assigned ? 'assigned' : 'authored'
      puts "  ##{pr.number} [#{pr.head_branch}] #{pr.title} (#{relationship})"
    end
  end

  add_subcmd(:amissing) do
    my_prs = pinned_manager.fetch_my_and_assigned_prs
    pinned_numbers = pinned_manager.load_pinned.map(&:number)
    missing = my_prs.reject { |pr| pinned_numbers.include?(pr.number) }

    if missing.empty?
      puts "All your PRs are already tracked"
      next
    end

    lines = ['---']
    missing.each do |pr|
      relationship = pr.assigned ? 'assigned' : 'authored'
      lines << ''
      lines << "# [#{relationship}] [#{pr.head_branch}] #{pr.title}"
      lines << "# url: #{pr.url}"
      lines << "- #{pr.number}"
    end

    input = yaml_input_file(content: lines.join("\n"), prefix: 'pr-amissing-')
    input.edit
    to_add = input.parsed_file || []
    input.cleanup

    added = 0
    to_add.each do |num|
      pr_info = pinned_manager.fetch_pr_info(num)
      next unless pr_info
      pinned_manager.pin(pr_info)
      puts "Tracked: ##{pr_info.number} #{pr_info.title}"
      added += 1
    end

    puts
    puts "Added #{added} PR(s) to tracking."
  end

  add_subcmd(:attach) do |ref = nil|
    pr_number = resolve_pr.call(ref)
    next unless pr_number

    pinned = pinned_manager.load_pinned
    pr = pinned.find { |p| p.number.to_s == pr_number.to_s }

    unless pr
      puts "PR ##{pr_number} not in pinned list — run 'h pr update' first"
      next
    end

    branch = pr.head_branch
    task_name = pr.task

    unless branch
      puts "PR ##{pr_number} has no branch info"
      next
    end

    # Resolve task session and working directory
    target_session = nil
    working_dir = Dir.pwd

    if task_name
      env = Environment.current rescue nil
      task = env&.find_task(task_name)
      if task
        target_session = task.session_name
        tree = task.tree
        working_dir = tree.path if tree
      end
    end

    unless target_session && system('tmux', 'has-session', '-t', target_session, out: File::NULL, err: File::NULL)
      puts "Task '#{task_name || '(none)'}' has no active tmux session"
      next
    end

    # Write a launcher: commit WIP if dirty, checkout the PR branch, then drop into shell
    script_path = "/tmp/h-pr-attach-#{pr_number}.sh"
    File.write(script_path, <<~SH)
      #!/usr/bin/env bash
      cd #{Shellwords.shellescape(working_dir)}

      if [ -n "$(git status --porcelain)" ]; then
        git add -A
        git commit -m "WIP"
        echo ""
        echo "WIP COMMIT: ALL UNCOMMITTED CHANGES HAVE BEEN COMMITTED BEFORE SWITCHING BRANCHES"
        echo ""
      fi

      git checkout #{Shellwords.shellescape(branch)}
      exec #{Shellwords.shellescape(ENV['SHELL'] || 'zsh')}
    SH
    FileUtils.chmod(0755, script_path)

    system('tmux', 'new-window', '-t', target_session, '-c', working_dir, script_path)
    system('tmux', 'switch-client', '-t', target_session)
  end

  add_subcmd(:rm) do |ref = nil|
    pinned = pinned_manager.load_pinned

    if pinned.empty?
      puts "No tracked PRs"
      next
    end

    pr_number = nil

    if ref.nil?
      lines = pinned.each_with_index.each_with_object({}) do |(pr, idx), h|
        h[pinned_manager.display_pinned(pr, idx)] = pr.number.to_s
      end

      pr_number = fuzzyfind_from_map(lines)
      unless pr_number
        puts "No PR selected"
        next
      end
    elsif ref =~ /^\d+$/
      pr_number = ref
    else
      puts "Usage: h pr rm [PR_NUMBER]"
      next
    end

    if pinned_manager.unpin(pr_number)
      puts "Removed PR ##{pr_number} from tracking"
    else
      puts "PR ##{pr_number} was not tracked"
    end
  end

  # === PR State ===

  add_subcmd(:ready) do |ref = nil|
    pr_number = resolve_pr.call(ref)
    next unless pr_number
    system('gh', 'pr', 'ready', pr_number.to_s)
  end

  add_subcmd(:'to-draft') do |ref = nil|
    pr_number = resolve_pr.call(ref)
    next unless pr_number
    system('gh', 'pr', 'ready', '--draft', pr_number.to_s)
  end

  # === PR Actions ===

  add_subcmd(:diff) do |ref = nil|
    pr_number = resolve_pr.call(ref)
    next unless pr_number
    system('gh', 'pr', 'diff', pr_number.to_s)
  end

  add_subcmd(:checkout) do |ref = nil|
    pr_number = resolve_pr.call(ref)
    next unless pr_number
    system('gh', 'pr', 'checkout', pr_number.to_s)
  end

  add_subcmd(:merge) do |ref = nil, *merge_args|
    pr_number = resolve_pr.call(ref)
    next unless pr_number
    system('gh', 'pr', 'merge', pr_number.to_s, *merge_args)
  end

  add_subcmd(:fix) do |*fix_args|
    opts = Hiiro::Options.parse(fix_args) do
      flag(:red, short: :r, desc: 'Fix all PRs with failing checks')
      flag(:run, short: :R, desc: 'Launch queue tasks immediately after queuing')
    end

    pinned = pinned_manager.load_pinned

    prs_to_fix = if opts.red
      failing = pinned.select { |pr| (c = pr.checks) && c['failed'].to_i > 0 }
      if failing.empty?
        puts "No PRs with failing checks"
        next
      end
      failing
    elsif opts.args.empty?
      # Default: fuzzy-select from failing PRs, fall back to all tracked
      failing = pinned.select { |pr| (c = pr.checks) && c['failed'].to_i > 0 }
      candidates = failing.empty? ? pinned : failing
      if candidates.empty?
        puts "No tracked PRs"
        next
      end
      lines = candidates.each_with_index.each_with_object({}) do |(pr, idx), h|
        h[pinned_manager.display_pinned(pr, idx)] = pr
      end
      selected = fuzzyfind_from_map(lines)
      next unless selected
      [selected]
    else
      # Resolve each positional arg as a PR ref
      opts.args.map { |ref|
        pr_num = resolve_pr.call(ref)
        next nil unless pr_num
        pinned.find { |p| p.number.to_s == pr_num.to_s }
      }.compact
    end

    if prs_to_fix.empty?
      puts "No PRs to fix"
      next
    end

    q = Hiiro::Queue.current(self)
    queued_names = []

    prs_to_fix.each do |pr|
      task_info = {
        task_name:    pr.task,
        tree_name:    pr.worktree,
        session_name: pr.tmux_session,
      }.compact
      task_info = nil if task_info.empty?

      result = q.add_with_frontmatter("/pr:fix #{pr.number}", task_info: task_info)
      if result
        puts "Queued fix for ##{pr.number}: #{pr.title}"
        queued_names << result[:name]
      else
        STDERR.puts "Failed to queue fix for ##{pr.number}"
      end
    end

    unless queued_names.empty?
      puts
      puts "Queued #{queued_names.length} fix task(s)."
      if opts.run
        puts "Launching..."
        queued_names.each { |name| q.launch_task(name) }
      else
        puts "Run 'h queue run' to start."
      end
    end
  end

  add_subcmd(:comment) do |ref = nil|
    pr_number = resolve_pr.call(ref)
    next unless pr_number

    tmpfile = Tempfile.new(['pr-comment-', '.md'])
    tmpfile.close
    edit_files(tmpfile.path)

    body = File.read(tmpfile.path).strip
    tmpfile.unlink

    if body.empty?
      puts "Aborted: empty comment"
      next
    end

    system('gh', 'pr', 'comment', pr_number.to_s, '--body', body)
  end

  # === Comment Templates ===

  TEMPLATES_DIR = File.join(Dir.home, '.config', 'hiiro', 'pr_templates')

  add_subcmd(:templates) do
    FileUtils.mkdir_p(TEMPLATES_DIR)
    files = Dir.glob(File.join(TEMPLATES_DIR, '*.md')).sort

    if files.empty?
      puts "No templates found. Use 'h pr new-template <name>' to create one."
      next
    end

    puts "Comment templates:"
    puts
    files.each do |f|
      name = File.basename(f, '.md')
      first_line = File.readlines(f).first&.strip || ''
      puts "  #{name.ljust(20)}  #{first_line}"
    end
  end

  add_subcmd(:'new-template') do |name = nil|
    FileUtils.mkdir_p(TEMPLATES_DIR)

    unless name
      STDERR.puts "Usage: h pr new-template <name>"
      next
    end

    path = File.join(TEMPLATES_DIR, "#{name}.md")

    if File.exist?(path)
      puts "Template '#{name}' already exists, opening for edit..."
    end

    edit_files(path)
    puts "Template saved: #{path}"
  end

  add_subcmd(:'from-template') do |ref = nil|
    FileUtils.mkdir_p(TEMPLATES_DIR)
    files = Dir.glob(File.join(TEMPLATES_DIR, '*.md')).sort

    if files.empty?
      STDERR.puts "No templates found. Use 'h pr new-template <name>' to create one."
      next
    end

    template_map = files.each_with_object({}) do |f, h|
      name = File.basename(f, '.md')
      first_line = File.readlines(f).first&.strip || ''
      h["#{name.ljust(20)}  #{first_line}"] = f
    end

    template_path = fuzzyfind_from_map(template_map)
    next unless template_path

    pr_number = resolve_pr.call(ref)
    next unless pr_number

    body = File.read(template_path).strip
    system('gh', 'pr', 'comment', pr_number.to_s, '--body', body)
  end

  # === PR List by Context ===

  add_subcmd(:'for-task') do |task_name = nil|
    tracked = pinned_manager.load_pinned

    if tracked.empty?
      puts "No tracked PRs"
      next
    end

    task_name ||= begin
      env = Environment.current rescue nil
      env&.task&.name
    end

    unless task_name
      STDERR.puts "Not in a task context. Pass a task name: h pr for-task <name>"
      next
    end

    matches = tracked.select { |pr| pr.task == task_name }

    if matches.empty?
      puts "No tracked PRs for task '#{task_name}'"
      next
    end

    puts "PRs for task '#{task_name}':"
    puts
    matches.each_with_index { |pr, i| puts pinned_manager.display_pinned(pr, i) }
  end

  # === Tags ===

  add_subcmd(:tag) do |*raw_args|
    opts = Hiiro::Options.parse(raw_args) do
      flag(:edit, short: 'e', desc: 'open YAML editor to bulk-tag multiple PRs')
    end

    if opts.edit
      pinned = pinned_manager.load_pinned

      if pinned.empty?
        puts "No tracked PRs to tag"
        next
      end

      yaml_content = <<~YAML
        # Select PRs to tag and list the tags to apply.
        # All listed PRs will receive all listed tags.
        # Lines starting with # are comments and are ignored.

        prs:
        #{pinned_manager.pr_yaml_lines(pinned).join("\n")}

        tags:
        -
      YAML

      input = yaml_input_file(content: yaml_content, prefix: 'pr-tag-')
      input.edit
      parsed = input.parsed_file
      input.cleanup

      unless parsed.is_a?(Hash)
        puts "Aborted: could not parse YAML"
        next
      end

      selected_numbers = Array(parsed['prs']).map(&:to_s).reject(&:empty?)
      new_tags         = Array(parsed['tags']).map(&:to_s).reject(&:empty?)

      if selected_numbers.empty? || new_tags.empty?
        puts "Aborted: need at least one PR and one tag"
        next
      end

      pinned = pinned_manager.load_pinned
      updated = 0
      selected_numbers.each do |num|
        pr = pinned.find { |p| p.number.to_s == num }
        next unless pr
        pr.tags = (Array(pr.tags) + new_tags).uniq
        updated += 1
        puts "Tagged ##{num} with: #{new_tags.join(', ')}"
      end

      pinned_manager.save_pinned(pinned)
      puts "Updated #{updated} PR(s)."
    else
      ref       = opts.args[0]
      tag_names = opts.args[1..]

      if ref.nil? || tag_names.empty?
        puts "Usage: h pr tag <ref> <tag> [tag2 ...]"
        puts "       h pr tag -e  (bulk edit mode)"
        next
      end

      pr_number = resolve_pr.call(ref)
      next unless pr_number

      pinned = pinned_manager.load_pinned
      pr = pinned.find { |p| p.number.to_s == pr_number.to_s }
      unless pr
        puts "PR ##{pr_number} not in tracked list"
        next
      end

      pr.tags = (Array(pr.tags) + tag_names).uniq
      pinned_manager.save_pinned(pinned)
      puts "Tagged ##{pr_number} with: #{tag_names.join(', ')}"
      puts "  Tags now: #{pr.tags.join(', ')}"
    end
  end

  add_subcmd(:untag) do |ref = nil, *tag_names|
    if ref.nil?
      puts "Usage: h pr untag <ref> [tag ...]  (omit tags to clear all)"
      next
    end

    pr_number = resolve_pr.call(ref)
    next unless pr_number

    pinned = pinned_manager.load_pinned
    pr = pinned.find { |p| p.number.to_s == pr_number.to_s }
    unless pr
      puts "PR ##{pr_number} not in tracked list"
      next
    end

    if tag_names.empty?
      pr.tags = nil
      puts "Cleared all tags from ##{pr_number}"
    else
      pr.tags = Array(pr.tags) - tag_names
      pr.tags = nil if pr.tags.empty?
      puts "Removed tag(s) #{tag_names.join(', ')} from ##{pr_number}"
    end

    pinned_manager.save_pinned(pinned)
  end

  add_subcmd(:tags) do
    pinned = pinned_manager.load_pinned
    by_tag = Hash.new { |h, k| h[k] = [] }

    pinned.each do |pr|
      Array(pr.tags).each { |t| by_tag[t] << pr }
    end

    if by_tag.empty?
      puts "No tagged PRs."
      next
    end

    by_tag.sort.each do |tag, prs|
      puts "\e[30;104m#{tag}\e[0m (#{prs.length})"
      slot_w  = prs.map { |pr| (pr.slot || 1).to_s.length }.max
      succ_w  = prs.filter_map { |pr| pr.checks&.dig('success')&.to_i&.to_s&.length }.max || 1
      total_w = prs.filter_map { |pr| pr.checks&.dig('total')&.to_i&.to_s&.length }.max || 1
      as_w    = prs.map { |pr| [pr.reviews&.dig('approved').to_i.to_s.length, 1].max }.max
      crs_w   = prs.map { |pr| [pr.reviews&.dig('changes_requested').to_i.to_s.length, 1].max }.max
      widths  = { slot: slot_w, succ: succ_w, total: total_w, as: as_w, crs: crs_w }
      prs.each_with_index do |pr, idx|
        puts "  #{display_pinned(pr, idx, widths: widths, oneline: true)}"
      end
    end
  end

  # === Multi-PR action commands (mCMD) ===
  # Each opens a YAML editor pre-filled with all tracked PRs.
  # Remove lines you don't want, then save to apply the action.

  add_subcmd(:mfix) do |*args|
    pinned = pinned_manager.load_pinned
    next puts "No tracked PRs" if pinned.empty?

    yaml_content = <<~YAML
      # Select PRs to queue fixes for (remove lines you don't want).
      # Set run: true to launch tasks immediately after queuing.

      prs:
      #{pinned_manager.pr_yaml_lines(pinned).join("\n")}

      run: false
    YAML

    input = yaml_input_file(content: yaml_content, prefix: 'pr-mfix-')
    input.edit
    parsed = input.parsed_file
    input.cleanup

    unless parsed.is_a?(Hash)
      puts "Aborted: could not parse YAML"
      next
    end

    selected_numbers = Array(parsed['prs']).map(&:to_s).reject(&:empty?)

    if selected_numbers.empty?
      puts "Aborted: no PRs selected"
      next
    end

    should_run = parsed['run'] == true
    q = Hiiro::Queue.current(self)
    queued_names = []

    selected_numbers.each do |num|
      pr = pinned.find { |p| p.number.to_s == num }
      next unless pr

      task_info = { task_name: pr.task, tree_name: pr.worktree, session_name: pr.tmux_session }.compact
      task_info = nil if task_info.empty?
      result = q.add_with_frontmatter("/pr:fix #{pr.number}", task_info: task_info)
      if result
        puts "Queued fix for ##{pr.number}: #{pr.title}"
        queued_names << result[:name]
      else
        STDERR.puts "Failed to queue fix for ##{pr.number}"
      end
    end

    if queued_names.any?
      puts
      puts "Queued #{queued_names.length} fix task(s)."
      if should_run
        puts "Launching..."
        queued_names.each { |name| q.launch_task(name) }
      else
        puts "Run 'h queue run' to start."
      end
    end
  end

  add_subcmd(:mopen) do |*args|
    pinned = pinned_manager.load_pinned
    next puts "No tracked PRs" if pinned.empty?

    yaml_content = <<~YAML
      # Select PRs to open in browser (remove lines you don't want).

      prs:
      #{pinned_manager.pr_yaml_lines(pinned).join("\n")}
    YAML

    input = yaml_input_file(content: yaml_content, prefix: 'pr-mopen-')
    input.edit
    parsed = input.parsed_file
    input.cleanup

    unless parsed.is_a?(Hash)
      puts "Aborted: could not parse YAML"
      next
    end

    selected_numbers = Array(parsed['prs']).map(&:to_s).reject(&:empty?)
    next puts "Aborted: no PRs selected" if selected_numbers.empty?

    selected_numbers.each do |num|
      pr = pinned.find { |p| p.number.to_s == num }
      pr&.url ? system('open', pr.url) : system('gh', 'pr', 'view', num, '--web')
    end
  end

  add_subcmd(:mmerge) do |*args|
    pinned = pinned_manager.load_pinned
    next puts "No tracked PRs" if pinned.empty?

    yaml_content = <<~YAML
      # Select PRs to merge (remove lines you don't want).
      # strategy: merge, squash, or rebase (leave blank for GitHub default)

      prs:
      #{pinned_manager.pr_yaml_lines(pinned).join("\n")}

      strategy:
    YAML

    input = yaml_input_file(content: yaml_content, prefix: 'pr-mmerge-')
    input.edit
    parsed = input.parsed_file
    input.cleanup

    unless parsed.is_a?(Hash)
      puts "Aborted: could not parse YAML"
      next
    end

    selected_numbers = Array(parsed['prs']).map(&:to_s).reject(&:empty?)

    if selected_numbers.empty?
      puts "Aborted: no PRs selected"
      next
    end

    strategy = parsed['strategy'].to_s.strip
    merge_args = strategy.empty? ? [] : ["--#{strategy}"]

    selected_numbers.each do |num|
      pr = pinned.find { |p| p.number.to_s == num }
      title = pr ? pr.title : num
      puts "Merging ##{num}: #{title}"
      system('gh', 'pr', 'merge', num, *merge_args)
    end
  end

  add_subcmd(:mready) do |*args|
    pinned = pinned_manager.load_pinned
    next puts "No tracked PRs" if pinned.empty?

    yaml_content = <<~YAML
      # Select PRs to mark as ready for review (remove lines you don't want).

      prs:
      #{pinned_manager.pr_yaml_lines(pinned).join("\n")}
    YAML

    input = yaml_input_file(content: yaml_content, prefix: 'pr-mready-')
    input.edit
    parsed = input.parsed_file
    input.cleanup

    unless parsed.is_a?(Hash)
      puts "Aborted: could not parse YAML"
      next
    end

    selected_numbers = Array(parsed['prs']).map(&:to_s).reject(&:empty?)
    next puts "Aborted: no PRs selected" if selected_numbers.empty?

    selected_numbers.each do |num|
      pr = pinned.find { |p| p.number.to_s == num }
      puts "Marking ##{num} as ready: #{pr ? pr.title : num}"
      system('gh', 'pr', 'ready', num)
    end
  end

  add_subcmd(:'mto-draft') do |*args|
    pinned = pinned_manager.load_pinned
    next puts "No tracked PRs" if pinned.empty?

    yaml_content = <<~YAML
      # Select PRs to convert to draft (remove lines you don't want).

      prs:
      #{pinned_manager.pr_yaml_lines(pinned).join("\n")}
    YAML

    input = yaml_input_file(content: yaml_content, prefix: 'pr-mto-draft-')
    input.edit
    parsed = input.parsed_file
    input.cleanup

    unless parsed.is_a?(Hash)
      puts "Aborted: could not parse YAML"
      next
    end

    selected_numbers = Array(parsed['prs']).map(&:to_s).reject(&:empty?)
    next puts "Aborted: no PRs selected" if selected_numbers.empty?

    selected_numbers.each do |num|
      pr = pinned.find { |p| p.number.to_s == num }
      puts "Converting ##{num} to draft: #{pr ? pr.title : num}"
      system('gh', 'pr', 'ready', '--draft', num)
    end
  end

  add_subcmd(:mrm) do |*args|
    pinned = pinned_manager.load_pinned
    next puts "No tracked PRs" if pinned.empty?

    yaml_content = <<~YAML
      # Select PRs to remove from tracking (remove lines you don't want).

      prs:
      #{pinned_manager.pr_yaml_lines(pinned).join("\n")}
    YAML

    input = yaml_input_file(content: yaml_content, prefix: 'pr-mrm-')
    input.edit
    parsed = input.parsed_file
    input.cleanup

    unless parsed.is_a?(Hash)
      puts "Aborted: could not parse YAML"
      next
    end

    selected_numbers = Array(parsed['prs']).map(&:to_s).reject(&:empty?)
    next puts "Aborted: no PRs selected" if selected_numbers.empty?

    selected_numbers.each do |num|
      pr = pinned.find { |p| p.number.to_s == num }
      pinned_manager.unpin(num)
      puts "Removed ##{num}: #{pr ? pr.title : num}"
    end
  end

  add_subcmd(:mcomment) do |*args|
    pinned = pinned_manager.load_pinned
    next puts "No tracked PRs" if pinned.empty?

    yaml_content = <<~YAML
      # Select PRs to comment on (remove lines you don't want).
      # Write your comment in the 'comment' field below.

      prs:
      #{pinned_manager.pr_yaml_lines(pinned).join("\n")}

      comment: |

    YAML

    input = yaml_input_file(content: yaml_content, prefix: 'pr-mcomment-')
    input.edit
    parsed = input.parsed_file
    input.cleanup

    unless parsed.is_a?(Hash)
      puts "Aborted: could not parse YAML"
      next
    end

    selected_numbers = Array(parsed['prs']).map(&:to_s).reject(&:empty?)
    body = parsed['comment'].to_s.strip

    if selected_numbers.empty?
      puts "Aborted: no PRs selected"
      next
    end

    if body.empty?
      puts "Aborted: empty comment"
      next
    end

    selected_numbers.each do |num|
      pr = pinned.find { |p| p.number.to_s == num }
      title = pr ? pr.title : num
      puts "Commenting on ##{num}: #{title}"
      system('gh', 'pr', 'comment', num, '--body', body)
    end
  end

  add_subcmd(:config) do |*args|
    make_child do
      add_subcmd(:path) do
        puts Hiiro::Git::Pr::PINNED_FILE
      end

      add_subcmd(:vim) do
        edit_files Hiiro::Git::Pr::PINNED_FILE
      end
    end.run
  end
end
