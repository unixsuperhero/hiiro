#!/usr/bin/env ruby

require 'hiiro'
require 'yaml'

Hiiro.run(*ARGV, plugins: [Pins]) do
  tmux = tmux_client
  Hiiro::Tmux.add_resolvers(self)

  home_config_path = Hiiro::Config.path('pane_homes.yml')

  load_homes = -> {
    return {} unless File.exist?(home_config_path)
    YAML.load_file(home_config_path) || {}
  }

  save_homes = ->(config) {
    File.write(home_config_path, config.to_yaml)
  }

  add_subcmd(:ls) { |*args|
    if args.empty?
      tmux.panes.each { |p| puts p.to_s }
    else
      system('tmux', 'list-panes', *args)
    end
  }

  add_subcmd(:lsa) { |*args|
    if args.empty?
      tmux.panes(all: true).each { |p| puts p.to_s }
    else
      system('tmux', 'list-panes', '-a', *args)
    end
  }

  add_subcmd(:split) { |*args|
    system('tmux', 'split-window', *args)
  }

  add_subcmd(:splitv) { |*args|
    if args.empty?
      tmux.split_window(horizontal: false)
    else
      system('tmux', 'split-window', '-v', *args)
    end
  }

  add_subcmd(:splith) { |*args|
    if args.empty?
      tmux.split_window(horizontal: true)
    else
      system('tmux', 'split-window', '-h', *args)
    end
  }

  add_subcmd(:kill) { |target = nil, *args|
    target = resolve(:pane, target)

    if target && args.empty?
      tmux.kill_pane(target)
    elsif target
      system('tmux', 'kill-pane', '-t', target, *args)
    end
  }

  add_subcmd(:swap) { |*args|
    system('tmux', 'swap-pane', *args)
  }

  add_subcmd(:zoom) { |target = nil, *args|
    if args.empty?
      tmux.resize_pane(target: target, zoom: true)
    else
      system('tmux', 'resize-pane', '-Z', *[target && "-t", target, *args].compact)
    end
  }

  add_subcmd(:capture) { |*args|
    if args.empty?
      content = tmux.capture_pane
      print content if content
    else
      system('tmux', 'capture-pane', *args)
    end
  }

  add_subcmd(:select) { |target = nil, *args|
    target = resolve(:pane, target)

    if target
      print target
    end
  }

  add_subcmd(:copy) { |target = nil, *args|
    target = resolve(:pane, target)

    if target
      Hiiro::Shell.pipe(target, 'pbcopy')
      puts "Copied pane '#{target}' to clipboard"
    end
  }

  add_subcmd(:sw, :switch) { |target = nil, *args|
    target = resolve(:pane, target)
    tmux.open_session(target) if target
  }

  add_subcmd(:home) { |*args|
    run_child(:home) do |h|
      h.add_subcmd(:ls) {
        homes = load_homes.call
        if homes.empty?
          puts "No home panes configured."
          puts "Use: h pane home add <name> <session> [path]"
        else
          homes.each do |name, cfg|
            path_str = cfg['path'] ? "  #{cfg['path']}" : ''
            puts "#{name.ljust(20)} #{cfg['session']}#{path_str}"
          end
        end
      }

      h.add_subcmd(:add) { |name, session, path = nil|
        unless name && session
          puts "Usage: h pane home add <name> <session> [path]"
          next
        end
        homes = load_homes.call
        homes[name] = { 'session' => session }
        homes[name]['path'] = File.expand_path(path) if path
        save_homes.call(homes)
        puts "Added '#{name}' → #{session}#{path ? " (#{File.expand_path(path)})" : ''}"
      }

      h.add_subcmd(:rm) { |name|
        unless name
          puts "Usage: h pane home rm <name>"
          next
        end
        homes = load_homes.call
        if homes.delete(name)
          save_homes.call(homes)
          puts "Removed home pane '#{name}'"
        else
          puts "Home pane '#{name}' not found"
        end
      }

      h.add_subcmd(:switch) { |name = nil|
        homes = load_homes.call

        if name.nil?
          if homes.empty?
            puts "No home panes configured. Use 'h pane home add <name> <session> [path]'"
            next
          end
          display_map = homes.each_with_object({}) do |(n, cfg), map|
            label = "#{n}  [#{cfg['session']}#{cfg['path'] ? "  #{cfg['path']}" : ''}]"
            map[label] = n
          end
          name = fuzzyfind_from_map(display_map)
          next unless name
        end

        cfg = homes[name]
        unless cfg
          matched = homes.keys.select { |k| k.start_with?(name) }
          case matched.size
          when 1
            name = matched.first
            cfg = homes[name]
          when 0
            puts "Home pane '#{name}' not found"
            next
          else
            puts "Ambiguous home pane '#{name}': #{matched.join(', ')}"
            next
          end
        end

        session = cfg['session']
        path = cfg['path']

        if !tmux.session_exists?(session)
          tmux.new_session(session, detached: true, start_directory: path, window_name: name)
        else
          window_names = `tmux list-windows -t #{session.shellescape} -F '\#{window_name}' 2>/dev/null`.lines(chomp: true)
          unless window_names.include?(name)
            dir = path || tmux.find_session(session)&.path
            tmux.new_window(name: name, target: session, start_directory: dir)
          end
        end

        target = "#{session}:#{name}"
        if tmux.in_tmux?
          system('tmux', 'switch-client', '-t', target)
        else
          system('tmux', 'attach-session', '-t', target)
        end
      }
    end
  }

  add_subcmd(:move) { |*args|
    system('tmux', 'move-pane', *args)
  }

  add_subcmd(:break) { |*args|
    if args.empty?
      tmux.break_pane
    else
      system('tmux', 'break-pane', *args)
    end
  }

  add_subcmd(:join) { |*args|
    system('tmux', 'join-pane', *args)
  }

  add_subcmd(:resize) { |*args|
    system('tmux', 'resize-pane', *args)
  }

  add_subcmd(:width) { |size, target = nil, *args|
    if target.nil? && args.empty?
      tmux.resize_pane(width: size)
    else
      system('tmux', 'resize-pane', '-x', size, *[target && "-t", target, *args].compact)
    end
  }

  add_subcmd(:height) { |size, target = nil, *args|
    if target.nil? && args.empty?
      tmux.resize_pane(height: size)
    else
      system('tmux', 'resize-pane', '-y', size, *[target && "-t", target, *args].compact)
    end
  }

  add_subcmd(:info) { |target = nil|
    pane = if target
      tmux.panes(all: true).find { |p| p.id == target }
    else
      tmux.current_pane
    end

    if pane
      puts pane.to_s
      puts "  Size: #{pane.width}x#{pane.height}"
      puts "  Command: #{pane.command}"
      puts "  Path: #{pane.path}"
    else
      puts "Pane not found"
    end
  }
end
