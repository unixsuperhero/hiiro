#!/usr/bin/env ruby

require "hiiro"
require "fileutils"
require "yaml"

Hiiro.load_env

class BranchManager
  attr_reader :hiiro

  def initialize(hiiro)
    @hiiro = hiiro
  end

  def save(branch_name = nil)
    branch_name ||= current_branch
    unless branch_name
      puts "ERROR: Not in a git repository"
      return false
    end

    entry = build_entry(branch_name)
    unless entry[:task]
      puts "WARNING: Not in a task session, saving without task info"
    end

    existing = Hiiro::Branch.find_by_name(branch_name)
    if existing
      puts "Updated branch '#{branch_name}' for task '#{entry[:task]}'"
    else
      puts "Saved branch '#{branch_name}' for task '#{entry[:task]}'"
    end

    save_branch(
      name:     entry[:name],
      worktree: entry[:worktree],
      task:     entry[:task],
      tmux:     entry[:tmux],
      sha:      entry[:sha]
    )
    show_entry(entry)
    true
  end

  def current
    branch_name = current_branch
    unless branch_name
      puts "ERROR: Not in a git repository"
      return false
    end

    entry = build_entry(branch_name)
    puts "Current branch info:"
    puts
    show_entry(entry)
  end

  # Returns entries as uniform hashes: [{name, task, ...}]
  # all: false → saved branches only; all: true → all local git branches
  def branch_entries(all: false)
    if all
      hiiro.git.branches(sort_by: 'authordate', ignore_case: true)
        .map { |name| {'name' => name, 'task' => nil} }
    else
      load_data['branches'] || []
    end
  end

  def branch_names(all: false)
    branch_entries(all: all).map { |e| e['name'] }
  end

  def saved_entry(branch_name)
    (load_data['branches'] || []).find { |b| b['name'] == branch_name }
  end

  def rename_saved(old_name, new_name)
    branch = Hiiro::Branch.find_by_name(old_name)
    return false unless branch
    branch.update(name: new_name, updated_at: Time.now.iso8601)
    save_yaml_backup
    true
  end

  def remove_saved(branch_name)
    branch = Hiiro::Branch.find_by_name(branch_name)
    return unless branch
    branch.destroy
    save_yaml_backup
  end

  def get_note(branch_name = nil)
    branch_name ||= current_branch
    Hiiro::Branch.find_by_name(branch_name)&.note
  end

  def set_note(text, branch_name = nil)
    branch_name ||= current_branch
    branch = Hiiro::Branch.find_by_name(branch_name)
    unless branch
      entry = build_entry(branch_name)
      branch = Hiiro::Branch.create(
        name:       branch_name,
        worktree:   entry[:worktree],
        task:       entry[:task],
        tmux_json:  Hiiro::DB::JSON.dump(entry[:tmux]),
        sha:        entry[:sha],
        created_at: Time.now.iso8601
      )
    end
    branch.update(note: text, updated_at: Time.now.iso8601)
    save_yaml_backup
  end

  def load_data
    Hiiro::Branch.ordered.all.each_with_object({ 'branches' => [] }) do |b, data|
      data['branches'] << {
        'name'       => b.name,
        'worktree'   => b.worktree,
        'task'       => b.task,
        'tmux'       => b.tmux.empty? ? nil : b.tmux,
        'sha'        => b.sha,
        'note'       => b.note,
        'created_at' => b.created_at
      }.compact
    end
  rescue => e
    warn "Branch DB read failed: #{e}"
    load_yaml_fallback
  end

  def build_entry(branch_name)
    current_task = Hiiro::Environment.current&.task rescue nil
    tmux_info = capture_tmux_info
    sha = `git rev-parse HEAD 2>/dev/null`.strip

    {
      name:     branch_name,
      sha:      sha.empty? ? nil : sha,
      worktree: current_task&.tree_name,
      task:     current_task&.name,
      tmux:     tmux_info
    }
  end

  private

  def current_branch
    hiiro.git.branch
  end

  def capture_tmux_info
    return nil unless ENV['TMUX']

    {
      'session' => `tmux display-message -p '#S'`.strip,
      'window'  => `tmux display-message -p '#W'`.strip,
      'pane'    => ENV['TMUX_PANE']
    }
  end

  def show_entry(entry)
    puts "  Branch: #{entry[:name]}"
    puts "  SHA: #{entry[:sha] || '(unknown)'}"
    puts "  Task: #{entry[:task] || '(none)'}"
    puts "  Worktree: #{entry[:worktree] || '(none)'}"
    if entry[:tmux]
      puts "  Tmux session: #{entry[:tmux]['session']}"
      puts "  Tmux window: #{entry[:tmux]['window']}"
      puts "  Tmux pane: #{entry[:tmux]['pane']}"
    end
  end

  def save_branch(name:, worktree:, task:, tmux: nil, sha: nil)
    existing = Hiiro::Branch.find_by_name(name)
    if existing
      existing.update(
        worktree:   worktree,
        task:       task,
        tmux_json:  Hiiro::DB::JSON.dump(tmux),
        sha:        sha,
        updated_at: Time.now.iso8601
      )
    else
      Hiiro::Branch.create(
        name:       name,
        worktree:   worktree,
        task:       task,
        tmux_json:  Hiiro::DB::JSON.dump(tmux),
        sha:        sha,
        created_at: Time.now.iso8601
      )
    end
    save_yaml_backup
  end

  def save_yaml_backup
    data = load_data
    FileUtils.mkdir_p(File.dirname(data_file))
    File.write(data_file, YAML.dump(data))
  rescue => e
    warn "Branch YAML backup failed: #{e}"
  end

  def load_yaml_fallback
    return {} unless File.exist?(data_file)
    YAML.safe_load_file(data_file) || {}
  rescue
    {}
  end

  def data_file
    File.join(Dir.home, '.config', 'hiiro', 'branches.yml')
  end
end

# Helper: find main or master branch name
FIND_BASE = -> {
  %w[main master].find { |b| system("git rev-parse --verify #{b} >/dev/null 2>&1") }
}

Hiiro.run(*ARGV) do
  manager   = BranchManager.new(self)
  tag_store = Hiiro::Tags.new(:branch)

  # Shared lambda: find a pinned PR by arg (number, URL, or fuzzy select)
  find_pr_by_arg = ->(arg, pinned) {
    if arg.nil?
      return nil if pinned.empty?
      lines = pinned.each_with_object({}) do |pr, h|
        h["##{pr.number} [#{pr.head_branch}] #{pr.title}"] = pr
      end
      require 'open3'
      selected, status = Open3.capture2('sk', '--no-sort', stdin_data: lines.keys.join("\n"))
      return nil unless status.success? && !selected.strip.empty?
      lines[selected.chomp]
    elsif arg.to_s =~ %r{/pull/(\d+)}
      num = $1
      pinned.find { |pr| pr.number.to_s == num }
    elsif arg.to_s =~ /^#?(\d+)$/
      num = $1
      pinned.find { |pr| pr.number.to_s == num }
    end
  }

  add_subcmd(:edit) { edit_files(__FILE__) }
  add_subcmd(:save) do |*save_args|
    opts        = Hiiro::Options.parse(save_args) { option(:tag, short: 't', desc: 'Tag to apply (repeatable)', multi: true) }
    branch_name = opts.args.first
    manager.save(branch_name)
    tags = Array(opts.tag).reject(&:empty?)
    if tags.any?
      branch_name ||= git.branch
      tag_store.add(branch_name, *tags)
      puts "Tagged with: #{tags.join(', ')}"
    end
  end

  add_subcmd(:saved) do |*saved_args|
    data = manager.load_data
    branches = data['branches'] || []

    if branches.empty?
      puts "No saved branches."
      next
    end

    filter = saved_args.first
    if filter
      branches = branches.select { |b| b['name'].include?(filter) || b['task'].to_s.include?(filter) }
      if branches.empty?
        puts "No saved branches matching '#{filter}'."
        next
      end
    end

    current = git.branch
    branches.each do |b|
      marker = b['name'] == current ? "* " : "  "
      task_str = b['task'] ? "  [#{b['task']}]" : ""
      puts "#{marker}#{b['name']}#{task_str}"
    end
  end

  add_subcmd(:current) { print `git branch --show-current` }

  add_subcmd(:info) do
    branch_name = git.branch
    unless branch_name
      puts "ERROR: Not in a git repository"
      next
    end

    entry = manager.build_entry(branch_name)
    saved = manager.saved_entry(branch_name)

    puts "Current branch info:"
    puts
    puts "  Branch:   #{entry[:name]}"
    puts "  SHA:      #{entry[:sha] || '(unknown)'}"
    puts "  Task:     #{entry[:task] || '(none)'}"
    puts "  Worktree: #{entry[:worktree] || '(none)'}"
    if entry[:tmux]
      puts "  Tmux session: #{entry[:tmux]['session']}"
      puts "  Tmux window:  #{entry[:tmux]['window']}"
      puts "  Tmux pane:    #{entry[:tmux]['pane']}"
    end

    base = FIND_BASE.call
    if base
      ahead  = `git rev-list --count #{base}..HEAD 2>/dev/null`.strip.to_i
      behind = `git rev-list --count HEAD..#{base} 2>/dev/null`.strip.to_i
      ahead_str  = ahead  > 0 ? "\e[32m↑#{ahead}\e[0m"  : "↑0"
      behind_str = behind > 0 ? "\e[31m↓#{behind}\e[0m" : "↓0"
      puts "  vs #{base}:  #{ahead_str} #{behind_str}"
    end

    if saved && saved['note']
      puts "  Note:     #{saved['note']}"
    end

    begin
      pinned_prs = Hiiro::PinnedPRManager.new.load_pinned
      pr = pinned_prs.find { |p| p.head_branch == branch_name }
      if pr
        puts "  PR:       ##{pr.number} (#{pr.state}) #{pr.title}"
        puts "  URL:      #{pr.url}" if pr.url
      end
    rescue
      # silently skip if PR data unavailable
    end
  end

  add_subcmd(:ls) do |*ls_args|
    opts = Hiiro::Options.parse(ls_args) do
      option(:tag, short: 't', desc: 'filter by tag (OR when multiple)', multi: true)
      flag(:all, short: 'a', desc: 'Show all local branches instead of just saved')
    end

    entries  = manager.branch_entries(all: opts.all)
    current  = git.branch
    tags_all = tag_store.all

    tag_filter = Array(opts.tag).reject(&:empty?)
    if tag_filter.any?
      entries = entries.select { |b| (Array(tags_all[b['name']]) & tag_filter).any? }
    end

    if entries.empty?
      msg = if tag_filter.any?
        "No #{opts.all ? '' : 'saved '}branches match tags: #{tag_filter.join(', ')}"
      elsif opts.all
        "No branches found."
      else
        "No saved branches. Use 'h branch save' or pass -a for all local branches."
      end
      puts msg
      next
    end

    entries.each do |b|
      name     = b['name']
      marker   = name == current ? "* " : "  "
      tags     = Array(tags_all[name])
      task_str = b['task'] ? " \e[90m[#{b['task']}]\e[0m" : ""
      tag_str  = tags.any? ? "  " + Hiiro::Tags.badges(tags) : ""
      puts "#{marker}#{name}#{task_str}#{tag_str}"
    end
  end

  add_subcmd(:search) do |*raw_args|
    opts  = Hiiro::Options.parse(raw_args) { flag(:all, short: 'a', desc: 'Search all local branches') }
    terms = opts.args

    if terms.empty?
      puts "Usage: h branch search TERM [TERM2 ...]"
      next
    end

    entries  = manager.branch_entries(all: opts.all)
    current  = git.branch
    tags_all = tag_store.all

    matched = entries.select do |b|
      terms.any? { |t|
        b['name'].match?(/#{Regexp.escape(t)}/i) ||
          Array(tags_all[b['name']]).any? { |tag| tag.match?(/#{Regexp.escape(t)}/i) }
      }
    end

    if matched.empty?
      puts "No #{opts.all ? '' : 'saved '}branches match: #{terms.join(', ')}"
      next
    end

    matched.each do |b|
      name     = b['name']
      marker   = name == current ? "* " : "  "
      tags     = Array(tags_all[name])
      task_str = b['task'] ? " \e[90m[#{b['task']}]\e[0m" : ""
      tag_str  = tags.any? ? "  " + Hiiro::Tags.badges(tags) : ""
      puts "#{marker}#{name}#{task_str}#{tag_str}"
    end
  end

  add_subcmd(:tag) do |*raw_args|
    opts     = Hiiro::Options.parse(raw_args) { flag(:edit, short: 'e', desc: 'open YAML editor to bulk-tag branches') }
    branches = git.branches(sort_by: 'authordate', ignore_case: true)

    if opts.edit
      branch_lines = branches.map { |b| "#{b}:" }
      yaml_content = <<~YAML
        # Select branches to tag and list the tags to apply.
        # All listed branches will receive all listed tags.

        #{branch_lines.join("\n  -\n")}
        -
      YAML

      require 'tempfile'
      tmpfile = Tempfile.new(['branch-tag-', '.yml'])
      tmpfile.write(yaml_content)
      tmpfile.close
      edit_files(tmpfile.path)

      parsed = YAML.safe_load(File.read(tmpfile.path)) rescue nil
      tmpfile.unlink

      unless parsed.is_a?(Hash)
        puts "Aborted: could not parse YAML"
        next
      end

      parsed.each do |branch, tags|
        tag_store.add(branch, *tags)
        puts "Tagged #{branch} with: #{tags.join(', ')}"
      end
    else
      branch   = opts.args[0] || git.branch
      tag_names = opts.args[1..]

      if tag_names&.count.to_i == 0
        puts "Usage: h branch tag [branch] <tag> [tag2 ...]"
        puts "       h branch tag -e  (bulk edit mode)"
        next
      end

      result = tag_store.add(branch, *tag_names)
      puts "Tagged #{branch} with: #{tag_names.join(', ')}"
      puts "  Tags now: #{result.join(', ')}"
    end
  end

  add_subcmd(:untag) do |*raw_args|
    branch    = raw_args[0] || git.branch
    tag_names = raw_args[1..]

    tag_store.remove(branch, *tag_names)
    if tag_names.empty?
      puts "Cleared all tags from #{branch}"
    else
      puts "Removed #{tag_names.join(', ')} from #{branch}"
    end
  end

  add_subcmd(:tags) do
    all = tag_store.all
    if all.empty?
      puts "No tagged branches."
      next
    end

    by_tag = Hash.new { |h, k| h[k] = [] }
    all.each { |branch, tags| tags.each { |t| by_tag[t] << branch } }

    by_tag.sort.each do |tag, brs|
      puts "#{Hiiro::Tags.badges([tag])} (#{brs.length})"
      brs.each { |b| puts "  #{b}" }
    end
  end

  add_subcmd(:select) do |*select_args|
    opts     = Hiiro::Options.parse(select_args) { flag(:all, short: 'a', desc: 'Select from all local branches') }
    branches = manager.branch_names(all: opts.all)

    lines = branches.each_with_object({}) do |name, h|
      h["  #{name}"] = name
    end

    if opts.args.any?
      lines = hash_matches?(lines, *opts.args)
    end

    require 'open3'
    selected, status = Open3.capture2('sk', '--no-sort', '--tac', stdin_data: lines.keys.join("\n"))

    if status.success? && !selected.strip.empty?
      puts lines[selected.chomp]
    end
  end

  add_subcmd(:copy) do |*copy_args|
    opts     = Hiiro::Options.parse(copy_args) { flag(:all, short: 'a', desc: 'Select from all local branches') }
    branches = manager.branch_names(all: opts.all)

    lines = branches.each_with_object({}) do |name, h|
      h["  #{name}"] = name
    end

    if opts.args.any?
      lines = hash_matches?(lines, *opts.args)
    end

    require 'open3'
    selected, status = Open3.capture2('sk', '--no-sort', '--tac', stdin_data: lines.keys.join("\n"))

    if status.success? && !selected.strip.empty?
      branch = lines[selected.chomp]
      Hiiro::Shell.pipe(branch, 'pbcopy')
      puts "Copied branch '#{branch}' to clipboard"
    end
  end

  add_subcmd(:co, :checkout) do |*co_args|
    opts   = Hiiro::Options.parse(co_args) { flag(:all, short: 'a', desc: 'Select from all local branches') }
    branch = opts.args.first

    unless branch
      branches = manager.branch_names(all: opts.all)
      require 'open3'
      selected, status = Open3.capture2('sk', '--no-sort', '--tac', stdin_data: branches.join("\n"))
      unless status.success? && !selected.strip.empty?
        puts "No branch selected"
        next
      end
      branch = selected.strip
    end

    system('git', 'checkout', branch, *opts.args[1..])
  end

  add_subcmd(:rm, :remove) do |*rm_args|
    opts   = Hiiro::Options.parse(rm_args) { flag(:all, short: 'a', desc: 'Select from all local branches') }
    branch = opts.args.first

    unless branch
      branches = manager.branch_names(all: opts.all)
      require 'open3'
      selected, status = Open3.capture2('sk', '--no-sort', '--tac', stdin_data: branches.join("\n"))
      unless status.success? && !selected.strip.empty?
        puts "No branch selected"
        next
      end
      branch = selected.strip
    end

    system('git', 'branch', '-d', branch, *opts.args[1..])
  end

  add_subcmd(:rename) do |new_name = nil, old_name = nil|
    unless new_name
      puts "Usage: h branch rename <new_name> [old_name]"
      next
    end

    old_name ||= git.branch

    unless system('git', 'branch', '-m', old_name, new_name)
      puts "ERROR: Could not rename branch"
      next
    end
    puts "Renamed '#{old_name}' → '#{new_name}'"

    remote = `git config branch.#{old_name}.remote 2>/dev/null`.strip
    if !remote.empty?
      if system('git', 'push', remote, ":#{old_name}", "#{new_name}")
        system('git', 'branch', '--set-upstream-to', "#{remote}/#{new_name}", new_name)
        puts "Updated remote #{remote}: deleted #{old_name}, pushed #{new_name}"
      else
        puts "WARNING: Could not update remote. Renamed locally only."
      end
    end

    if manager.rename_saved(old_name, new_name)
      puts "Updated saved branch record"
    end
  end

  add_subcmd(:status) do |*args|
    opts    = Hiiro::Options.parse(args) { flag(:all, short: 'a', desc: 'Show all local branches') }
    entries = manager.branch_entries(all: opts.all)
    current = git.branch
    base    = FIND_BASE.call || 'HEAD'

    if entries.empty?
      puts opts.all ? "No branches found." : "No saved branches. Use -a to show all."
      next
    end

    pinned_prs = begin
      Hiiro::PinnedPRManager.new.load_pinned
    rescue
      []
    end
    pr_by_branch = pinned_prs.each_with_object({}) { |pr, h| h[pr.head_branch] = pr }

    name_width = [entries.map { |b| b['name'].length }.max, 20].max

    entries.each do |b|
      name   = b['name']
      marker = name == current ? "* " : "  "

      ahead  = `git rev-list --count #{base}..#{name} 2>/dev/null`.strip.to_i
      behind = `git rev-list --count #{name}..#{base} 2>/dev/null`.strip.to_i

      ahead_str  = ahead  > 0 ? "\e[32m↑#{ahead}\e[0m"  : "\e[90m↑0\e[0m"
      behind_str = behind > 0 ? "\e[31m↓#{behind}\e[0m" : "\e[90m↓0\e[0m"

      pr       = pr_by_branch[name]
      pr_str   = pr ? " \e[36m##{pr.number} #{pr.state}\e[0m" : ""
      task_str = b['task'] ? " \e[90m[#{b['task']}]\e[0m" : ""

      puts "#{marker}#{name.ljust(name_width)}  #{ahead_str} #{behind_str}#{pr_str}#{task_str}"
    end
  end

  add_subcmd(:merged) do |*args|
    opts = Hiiro::Options.parse(args) { flag(:all, short: 'a', desc: 'Show all merged branches, not just saved') }
    base = FIND_BASE.call || 'main'

    all_merged = `git branch --merged #{base} 2>/dev/null`
      .lines.map { |b| b.strip.sub(/^\* /, '') }
      .reject { |b| b.empty? || %w[main master].include?(b) }

    if all_merged.empty?
      puts "No merged branches."
      next
    end

    displayed = if opts.all
      all_merged
    else
      saved_names = manager.branch_names.to_set
      filtered = all_merged.select { |b| saved_names.include?(b) }
      if filtered.empty?
        puts "No saved merged branches (use -a to show all)."
        next
      end
      filtered
    end

    current = git.branch
    displayed.each do |b|
      marker = b == current ? "* " : "  "
      puts "#{marker}#{b}"
    end
  end

  add_subcmd(:clean) do |*args|
    opts = Hiiro::Options.parse(args) do
      flag(:all,   short: 'a', desc: 'Include all merged branches, not just saved')
      flag(:force, short: 'f', desc: 'Delete all without confirmation prompt')
    end
    base = FIND_BASE.call || 'main'

    all_merged = `git branch --merged #{base} 2>/dev/null`
      .lines.map { |b| b.strip.sub(/^\* /, '') }
      .reject { |b| b.empty? || %w[main master].include?(b) }

    to_consider = if opts.all
      all_merged
    else
      saved_names = manager.branch_names.to_set
      all_merged.select { |b| saved_names.include?(b) }
    end

    if to_consider.empty?
      puts "No #{opts.all ? '' : 'saved '}merged branches to clean."
      next
    end

    to_delete = if opts.force
      to_consider
    else
      require 'open3'
      selected, status = Open3.capture2('sk', '--multi', '--no-sort', stdin_data: to_consider.join("\n"))
      if !status.success? || selected.strip.empty?
        puts "Nothing selected."
        next
      end
      selected.lines.map(&:strip).reject(&:empty?)
    end

    to_delete.each do |b|
      if system('git', 'branch', '-d', b)
        puts "Deleted #{b}"
        manager.remove_saved(b)
      else
        puts "Could not delete #{b} (may need -D for unmerged; skipping)"
      end
    end
  end

  add_subcmd(:recent) do |n = nil|
    n = (n || 10).to_i

    recent_branches = `git reflog --format="%D" 2>/dev/null`
      .lines
      .flat_map { |line| line.scan(/HEAD -> ([^,\n]+)/) }
      .flatten
      .uniq
      .reject { |b| b.strip.empty? }
      .first(n)

    if recent_branches.empty?
      puts "No recent branches found in reflog."
      next
    end

    current     = git.branch
    tags_all    = tag_store.all
    saved_names = manager.branch_names.to_set

    recent_branches.each do |name|
      marker     = name == current ? "* " : "  "
      tags       = Array(tags_all[name])
      saved_str  = saved_names.include?(name) ? " \e[90m[saved]\e[0m" : ""
      tag_str    = tags.any? ? "  " + Hiiro::Tags.badges(tags) : ""
      puts "#{marker}#{name}#{saved_str}#{tag_str}"
    end
  end

  add_subcmd(:note) do |*note_args|
    opts = Hiiro::Options.parse(note_args) { flag(:clear, desc: 'Clear the note for this branch') }

    if opts.clear
      manager.set_note(nil)
      puts "Note cleared."
      next
    end

    text = opts.args.join(' ')

    if text.empty?
      note = manager.get_note
      puts note ? note : "(no note)"
    else
      manager.set_note(text)
      puts "Note saved: #{text}"
    end
  end

  add_subcmd(:'for-task') do |task_name = nil|
    task_name ||= begin
      Hiiro::Environment.current&.task&.name
    rescue
      nil
    end

    unless task_name
      puts "Usage: h branch for-task <task_name>"
      puts "       (or run from a task session to use current task)"
      next
    end

    data     = manager.load_data
    branches = (data['branches'] || []).select { |b| b['task'] == task_name }

    if branches.empty?
      puts "No saved branches for task '#{task_name}'"
      next
    end

    current = git.branch
    puts "Branches for task '#{task_name}':"
    branches.each do |b|
      marker = b['name'] == current ? "* " : "  "
      puts "#{marker}#{b['name']}"
    end
  end

  add_subcmd(:'for-pr', :pr) do |arg = nil|
    pinned_prs = Hiiro::PinnedPRManager.new.load_pinned rescue []
    pr = find_pr_by_arg.call(arg, pinned_prs)

    if pr.nil?
      puts arg ? "No tracked PR found for: #{arg}" : "No PR selected."
      next
    end

    if pr.head_branch
      puts pr.head_branch
    else
      puts "PR ##{pr.number} has no branch info"
    end
  end

  add_subcmd(:duplicate) { |new_name = nil, source = nil|
    unless new_name
      puts "Usage: h branch duplicate <new_name> [source_branch]"
      puts "  Creates a copy of source_branch (or current branch) as new_name"
      next
    end

    source ||= git.branch
    system('git', 'branch', new_name, source)
    puts "Created branch '#{new_name}' from '#{source}'"
  }

  add_subcmd(:test) { |*test_args|
    opts = Hiiro::Options.parse(test_args) do
      option :remote, short: 'r', default: 'origin', desc: 'Remote name'
      option :from, short: 'f', desc: 'Local branch or commit to push'
      option :to, short: 't', desc: 'Remote branch name'
      flag :force, short: 'F', desc: 'Force push'
      flag :set_upstream, short: 'u', desc: 'Set upstream tracking'
    end

    if opts.help?
      help(opts)
      return
    end

    {
      remote_as_method: opts.remote,
      remote_as_sym_key: opts[:remote],
      remote_as_string_key: opts['remote'],
      force_as_method: opts.force,
      force_as_sym_key: opts[:force],
      force_as_string_key: opts['force'],
    }.each do |k,v|
      puts "#{k} => #{v}"
    end
  }

  add_subcmd(:push) { |*push_args|
    opts = Hiiro::Options.parse(push_args) do
      option :remote, short: 'r', default: 'origin', desc: 'Remote name'
      option :from, short: 'f', desc: 'Local branch or commit to push'
      option :to, short: 't', desc: 'Remote branch name'
      flag :force, short: 'F', desc: 'Force push'
      flag :set_upstream, short: 'u', desc: 'Set upstream tracking'
    end

    local_ref = opts[:from] || git.branch
    remote_branch = opts[:to] || local_ref

    git_args = ['git', 'push']
    git_args << '--force' if opts[:force]
    git_args << '-u' if opts[:set_upstream]
    git_args << opts[:remote]
    git_args << "#{local_ref}:#{remote_branch}"

    puts "Pushing #{local_ref} to #{opts[:remote]}/#{remote_branch}..."
    system(*git_args)
  }

  add_subcmd(:diff) { |*diff_args|
    case diff_args.length
    when 0
      base = %w[main master].find { |b| system("git rev-parse --verify #{b} >/dev/null 2>&1") } || 'HEAD~1'
      range = "#{base}..HEAD"
    when 1
      range = "#{diff_args[0]}..HEAD"
    else
      from, to = diff_args[0..1]
      range = "#{from}..#{to}"
    end

    system('git', 'log', '--oneline', '--decorate', range)
  }

  add_subcmd(:changed) { |*changed_args|
    show_all = changed_args.delete('-a') || changed_args.delete('--all')
    upstream = changed_args.first

    upstream ||= %w[origin/master master origin/main main].find { |ref|
      system("git rev-parse --verify #{ref} >/dev/null 2>&1")
    }

    unless upstream
      puts "Cannot find master or origin/master"
      next
    end

    forkpoint = `git merge-base --fork-point #{upstream} HEAD 2>/dev/null`.strip
    if forkpoint.empty?
      forkpoint = `git merge-base #{upstream} HEAD 2>/dev/null`.strip
    end

    if forkpoint.empty?
      puts "Could not find fork point"
      next
    end

    if show_all
      system('git', 'diff', '--name-only', "#{forkpoint}...HEAD")
    else
      system('git', 'diff', '--name-only', '--relative', "#{forkpoint}...HEAD")
    end
  }

  add_subcmd(:ahead) { |*ahead_args|
    case ahead_args.length
    when 0
      base = %w[main master].find { |b| system("git rev-parse --verify #{b} >/dev/null 2>&1") } || 'HEAD~1'
      ahead_of = base
      branch = 'HEAD'
    when 1
      ahead_of = ahead_args[0]
      branch = 'HEAD'
    else
      ahead_of, branch = ahead_args[0..1]
    end

    count = `git rev-list --count #{ahead_of}..#{branch}`.strip.to_i
    puts "#{branch} is #{count} commit(s) ahead of #{ahead_of}"
  }

  add_subcmd(:behind) { |*behind_args|
    case behind_args.length
    when 0
      base = %w[main master].find { |b| system("git rev-parse --verify #{b} >/dev/null 2>&1") } || 'HEAD~1'
      behind_of = base
      branch = 'HEAD'
    when 1
      behind_of = behind_args[0]
      branch = 'HEAD'
    else
      behind_of, branch = behind_args[0..1]
    end

    count = `git rev-list --count #{branch}..#{behind_of}`.strip.to_i
    puts "#{branch} is #{count} commit(s) behind #{behind_of}"
  }

  add_subcmd(:log) { |upstream = nil|
    upstream ||= %w[origin/master master origin/main main].find { |ref|
      system("git rev-parse --verify #{ref} >/dev/null 2>&1")
    }

    unless upstream
      puts "Cannot find master or origin/master"
      next
    end

    forkpoint = `git merge-base --fork-point #{upstream} HEAD 2>/dev/null`.strip
    if forkpoint.empty?
      forkpoint = `git merge-base #{upstream} HEAD 2>/dev/null`.strip
    end

    if forkpoint.empty?
      puts "Could not find fork point"
      next
    end

    system('git', 'log', '--oneline', '--decorate', "#{forkpoint}..HEAD")
  }

  add_subcmd(:q, :query) { |*args|
    def branch_query(args)
      opts = Hiiro::Options.parse(args) { flag(:all, short: :a, desc: 'show all rows (no limit)') }
      query_args = opts.args
      db = Hiiro::DB.connection
      limit = opts.all ? nil : 50

      if query_args.empty?
        ds = db[:branches]
        ds = ds.limit(limit) if limit
        rows = ds.all
      elsif query_args[0].include?(' ') || query_args[0].upcase =~ /\A(SELECT|INSERT|UPDATE|DELETE|WITH)/
        sql = query_args.join(' ')
        rows = db.fetch(sql).all
        rows = rows.first(limit) if limit
      else
        conditions = query_args.each_with_object({}) do |pair, h|
          k, v = pair.split('=', 2)
          h[k] = v if k && v
        end
        ds = db[:branches]
        conditions.each { |k, v| ds = ds.where(k.to_sym => v) }
        ds = ds.limit(limit) if limit
        rows = ds.all
      end

      return puts "(no results)" if rows.empty?
      keys = rows.first.keys
      col_widths = keys.map { |k| [k.to_s.length, rows.map { |r| r[k].to_s.length }.max].max.clamp(0, 60) }
      header = keys.each_with_index.map { |k, i| k.to_s.ljust(col_widths[i]) }.join("  ")
      puts header
      puts "-" * header.length
      rows.each do |row|
        puts keys.each_with_index.map { |k, i|
          val = row[k].to_s; val = val[0..57] + "..." if val.length > 60; val.ljust(col_widths[i])
        }.join("  ")
      end
      puts "(#{rows.length} rows)"
    end
    branch_query(args)
  }

  add_subcmd(:forkpoint) { |upstream = nil, branch = nil|
    branch ||= 'HEAD'
    upstream ||= %w[origin/master master origin/main main].find { |ref|
      system("git rev-parse --verify #{ref} >/dev/null 2>&1")
    }

    unless upstream
      puts "Cannot find master or origin/master"
      next
    end

    forkpoint = `git merge-base --fork-point #{upstream} #{branch} 2>/dev/null`.strip

    if forkpoint.empty?
      forkpoint = `git merge-base #{upstream} #{branch} 2>/dev/null`.strip
    end

    if forkpoint.empty?
      puts "Could not find fork point between #{upstream} and #{branch}"
    else
      puts forkpoint
    end
  }

  add_subcmd(:ancestor) { |*ancestor_args|
    case ancestor_args.length
    when 0
      base = %w[main master].find { |b| system("git rev-parse --verify #{b} >/dev/null 2>&1") }
      unless base
        puts "Cannot find main or master branch"
        next
      end
      ancestor = base
      descendant = 'HEAD'
    when 1
      ancestor = ancestor_args[0]
      descendant = 'HEAD'
    else
      ancestor, descendant = ancestor_args[0..1]
    end

    if system("git merge-base --is-ancestor #{ancestor} #{descendant}")
      puts "Yes, #{ancestor} is an ancestor of #{descendant}"
    else
      puts "No, #{ancestor} is NOT an ancestor of #{descendant}"
    end
  }
end
