#!/usr/bin/env ruby

require "hiiro"
require "fileutils"
require "yaml"

Hiiro.load_env

class BranchManager
  attr_reader :hiiro

  def initialize(hiiro)
    @hiiro = hiiro
  end

  def save
    branch_name = current_branch
    unless branch_name
      puts "ERROR: Not in a git repository"
      return false
    end

    entry = build_entry(branch_name)
    unless entry[:task]
      puts "WARNING: Not in a task session, saving without task info"
    end

    data = load_data
    data['branches'] ||= []

    # Check if this branch is already recorded for this task
    existing = data['branches'].find do |b|
      b['name'] == branch_name && b['task'] == entry[:task]
    end

    if existing
      # Update existing entry
      existing.merge!(entry.transform_keys(&:to_s))
      existing['updated_at'] = Time.now.iso8601
      puts "Updated branch '#{branch_name}' for task '#{entry[:task]}'"
    else
      # Add new entry
      data['branches'] << entry.transform_keys(&:to_s).merge('created_at' => Time.now.iso8601)
      puts "Saved branch '#{branch_name}' for task '#{entry[:task]}'"
    end

    save_data(data)
    show_entry(entry)
    true
  end

  def current
    branch_name = current_branch
    unless branch_name
      puts "ERROR: Not in a git repository"
      return false
    end

    entry = build_entry(branch_name)
    puts "Current branch info:"
    puts
    show_entry(entry)
  end

  private

  def current_branch
    hiiro.git.branch
  end

  def build_entry(branch_name)
    current_task = Environment.current.task
    tmux_info = capture_tmux_info

    {
      name: branch_name,
      worktree: current_task&.tree_name,
      task: current_task&.name,
      tmux: tmux_info
    }
  end

  def capture_tmux_info
    return nil unless ENV['TMUX']

    {
      'session' => `tmux display-message -p '#S'`.strip,
      'window' => `tmux display-message -p '#W'`.strip,
      'pane' => ENV['TMUX_PANE']
    }
  end

  def show_entry(entry)
    puts "  Branch: #{entry[:name]}"
    puts "  Task: #{entry[:task] || '(none)'}"
    puts "  Worktree: #{entry[:worktree] || '(none)'}"
    if entry[:tmux]
      puts "  Tmux session: #{entry[:tmux]['session']}"
      puts "  Tmux window: #{entry[:tmux]['window']}"
      puts "  Tmux pane: #{entry[:tmux]['pane']}"
    end
  end

  def data_file
    File.join(Dir.home, '.config', 'hiiro', 'branches.yml')
  end

  def load_data
    return {} unless File.exist?(data_file)
    YAML.safe_load_file(data_file) || {}
  end

  def save_data(data)
    FileUtils.mkdir_p(File.dirname(data_file))
    File.write(data_file, YAML.dump(data))
  end
end

Hiiro.run(*ARGV) do
  manager = BranchManager.new(self)

  default_base = lambda {
    %w[main master].find { |b| system("git rev-parse --verify #{b} >/dev/null 2>&1") }
  }

  default_upstream = lambda {
    %w[origin/master master origin/main main].find { |ref|
      system("git rev-parse --verify #{ref} >/dev/null 2>&1")
    }
  }

  fork_point = lambda { |upstream, branch = 'HEAD'|
    fp = `git merge-base --fork-point #{upstream} #{branch} 2>/dev/null`.strip
    fp = `git merge-base #{upstream} #{branch} 2>/dev/null`.strip if fp.empty?
    fp.empty? ? nil : fp
  }

  add_subcmd(:edit) { system(ENV['EDITOR'] || 'nvim', __FILE__) }
  add_subcmd(:save) { manager.save }
  add_subcmd(:current) { print `git branch --show-current` }
  add_subcmd(:info) { manager.current }

  select_branch = lambda { |*filter_args|
    branches = git.branches(sort_by: 'authordate', ignore_case: true)
    lines = branches.each_with_object({}) { |name, h| h["  #{name}"] = name }
    lines = hash_matches?(lines, *filter_args) if filter_args.any?
    fuzzyfind_from_map(lines)
  }

  add_subcmd(:select) do |*select_args|
    branch = select_branch.call(*select_args)
    puts branch if branch
  end

  add_subcmd(:copy) do |*copy_args|
    branch = select_branch.call(*copy_args)
    if branch
      Hiiro::Shell.pipe(branch, 'pbcopy')
      puts "Copied branch '#{branch}' to clipboard"
    end
  end

  add_subcmd(:co, :checkout) { |branch = nil, *checkout_args|
    branch ||= select_branch.call
    next puts("No branch selected") unless branch
    system('git', 'checkout', branch, *checkout_args)
  }

  add_subcmd(:rm, :remove) { |branch = nil, *remove_args|
    branch ||= select_branch.call
    next puts("No branch selected") unless branch
    system('git', 'branch', '-d', branch, *remove_args)
  }

  add_subcmd(:duplicate) { |new_name = nil, source = nil|
    unless new_name
      puts "Usage: h branch duplicate <new_name> [source_branch]"
      puts "  Creates a copy of source_branch (or current branch) as new_name"
      next
    end

    source ||= git.branch
    system('git', 'branch', new_name, source)
    puts "Created branch '#{new_name}' from '#{source}'"
  }

  add_subcmd(:test) { |*test_args|
    opts = Hiiro::Options.parse(test_args) do
      option :remote, short: 'r', default: 'origin', desc: 'Remote name'
      option :from, short: 'f', desc: 'Local branch or commit to push'
      option :to, short: 't', desc: 'Remote branch name'
      flag :force, short: 'F', desc: 'Force push'
      flag :set_upstream, short: 'u', desc: 'Set upstream tracking'
    end

    if opts.help?
      help(opts)
      return
    end

    {
      remote_as_method: opts.remote,
      remote_as_sym_key: opts[:remote],
      remote_as_string_key: opts['remote'],
      force_as_method: opts.force,
      force_as_sym_key: opts[:force],
      force_as_string_key: opts['force'],
    }.each do |k,v|
      puts "#{k} => #{v}"
    end
  }

  add_subcmd(:push) { |*push_args|
    opts = Hiiro::Options.parse(push_args) do
      option :remote, short: 'r', default: 'origin', desc: 'Remote name'
      option :from, short: 'f', desc: 'Local branch or commit to push'
      option :to, short: 't', desc: 'Remote branch name'
      flag :force, short: 'F', desc: 'Force push'
      flag :set_upstream, short: 'u', desc: 'Set upstream tracking'
    end

    local_ref = opts[:from] || git.branch
    remote_branch = opts[:to] || local_ref

    git_args = ['git', 'push']
    git_args << '--force' if opts[:force]
    git_args << '-u' if opts[:set_upstream]
    git_args << opts[:remote]
    git_args << "#{local_ref}:#{remote_branch}"

    puts "Pushing #{local_ref} to #{opts[:remote]}/#{remote_branch}..."
    system(*git_args)
  }

  add_subcmd(:diff) { |*diff_args|
    case diff_args.length
    when 0
      range = "#{default_base.call || 'HEAD~1'}..HEAD"
    when 1
      range = "#{diff_args[0]}..HEAD"
    else
      range = "#{diff_args[0]}..#{diff_args[1]}"
    end

    system('git', 'log', '--oneline', '--decorate', range)
  }

  add_subcmd(:changed) { |*changed_args|
    show_all = changed_args.delete('-a') || changed_args.delete('--all')
    upstream = changed_args.first || default_upstream.call
    next puts("Cannot find master or origin/master") unless upstream

    fp = fork_point.call(upstream)
    next puts("Could not find fork point") unless fp

    if show_all
      system('git', 'diff', '--name-only', "#{fp}...HEAD")
    else
      system('git', 'diff', '--name-only', '--relative', "#{fp}...HEAD")
    end
  }

  add_subcmd(:ahead) { |ref = nil, branch = 'HEAD'|
    ref ||= default_base.call || 'HEAD~1'
    count = `git rev-list --count #{ref}..#{branch}`.strip.to_i
    puts "#{branch} is #{count} commit(s) ahead of #{ref}"
  }

  add_subcmd(:behind) { |ref = nil, branch = 'HEAD'|
    ref ||= default_base.call || 'HEAD~1'
    count = `git rev-list --count #{branch}..#{ref}`.strip.to_i
    puts "#{branch} is #{count} commit(s) behind #{ref}"
  }

  add_subcmd(:log) { |upstream = nil|
    upstream ||= default_upstream.call
    next puts("Cannot find master or origin/master") unless upstream

    fp = fork_point.call(upstream)
    next puts("Could not find fork point") unless fp

    system('git', 'log', '--oneline', '--decorate', "#{fp}..HEAD")
  }

  add_subcmd(:forkpoint) { |upstream = nil, branch = 'HEAD'|
    upstream ||= default_upstream.call
    next puts("Cannot find master or origin/master") unless upstream

    fp = fork_point.call(upstream, branch)
    if fp
      puts fp
    else
      puts "Could not find fork point between #{upstream} and #{branch}"
    end
  }

  add_subcmd(:ancestor) { |*ancestor_args|
    case ancestor_args.length
    when 0
      base = default_base.call
      next puts("Cannot find main or master branch") unless base
      ancestor, descendant = base, 'HEAD'
    when 1
      ancestor, descendant = ancestor_args[0], 'HEAD'
    else
      ancestor, descendant = ancestor_args[0..1]
    end

    if system("git merge-base --is-ancestor #{ancestor} #{descendant}")
      puts "Yes, #{ancestor} is an ancestor of #{descendant}"
    else
      puts "No, #{ancestor} is NOT an ancestor of #{descendant}"
    end
  }
end
