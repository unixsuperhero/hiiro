#!/usr/bin/env ruby

require 'yaml'
require 'fileutils'
require 'time'
require 'pry'
require 'tempfile'
require "hiiro"

opts = Hiiro::Options.setup {
  option(:shorthand, short: :s, desc: 'Shorthand alias for the link')
  option(:tag, short: :t, multi: true, desc: 'Tag for the link (repeatable)')
  option(:tags, multi: true, desc: 'Tag for the link (alias for --tag, repeatable)')
}

class LinkManager
  LINKS_FILE = File.join(Dir.home, '.config/hiiro/links.yml')
  LINK_TEMPLATE = {
    'url' => '',
    'description' => '',
    'shorthand' => nil,
    'created_at' => Time.now.iso8601,
  }

  class Link
    attr_accessor :url, :description, :shorthand, :created_at

    def initialize(url:, description: '', shorthand: nil, created_at: Time.now.iso8601)
      @url = url
      @description = description
      @shorthand = shorthand
      @created_at = created_at
    end

    def self.from_hash(hash)
      new(
        url: hash['url'],
        description: hash['description'] || '',
        shorthand: hash['shorthand'],
        created_at: hash['created_at'] || Time.now.iso8601
      )
    end

    def to_h
      {
        'url' => @url,
        'description' => @description,
        'shorthand' => @shorthand,
        'created_at' => @created_at
      }
    end

    def to_yaml
      to_h.to_yaml
    end

    def matches?(*terms)
      searchable = [
        @url,
        @description,
        @shorthand
      ].compact.join(' ').downcase

      terms.all? { |term| searchable.downcase.include?(term.downcase) }
    end

    def display_string(index = nil)
      num = index ? "#{(index + 1).to_s.rjust(3)}." : ""
      shorthand_str = @shorthand ? " [#{@shorthand}]" : ""
      desc_str = @description.to_s.empty? ? "" : " - #{@description}"
      "#{num}#{shorthand_str} #{@url}#{desc_str}".strip
    end
  end

  attr_reader :links_file

  def initialize(links_file = LINKS_FILE)
    @links_file = links_file
  end

  def ensure_links_file
    dir = File.dirname(@links_file)
    FileUtils.mkdir_p(dir) unless Dir.exist?(dir)
    File.write(@links_file, [].to_yaml) unless File.exist?(@links_file)
  end

  def hash_matches?(links_hash, *args)
    links_hash.select { |line, link| link.matches?(*args) }
  end

  def search_links(links, *args)
    links.select { |link| link.matches?(*args) }
  end

  def load_link_hash(links=nil)
    links ||= load_links

    links.each_with_index.each_with_object({}) do |(link, idx), h|
      h[link.display_string(idx)] = link
    end
  end

  def load_links
    Hiiro::Link.ordered
  rescue => e
    warn "Link DB read failed: #{e}"
    load_links_from_yaml
  end

  def load_links_from_yaml
    ensure_links_file
    links_data = YAML.load_file(@links_file) || []
    links_data.map { |hash| Link.from_hash(hash) }
  end

  def edit_links(links=nil)
    links_array = if links.nil?
      [LINK_TEMPLATE]
    elsif links.is_a?(Array)
      links.map { |link| link.respond_to?(:to_h) ? link.to_h : link }
    else
      [links.respond_to?(:to_h) ? links.to_h : links]
    end

    tmpfile = Tempfile.new(['link-edit-', '.yml'])
    tmpfile.write(links_array.to_yaml)
    tmpfile.close

    system(ENV['EDITOR'] || 'vim', tmpfile.path)

    updated_data = YAML.load_file(tmpfile.path)
    tmpfile.unlink

    # Handle both array and single hash results
    updated_array = updated_data.is_a?(Array) ? updated_data : [updated_data]
    updated_array.map { |hash| Link.from_hash(hash) }
  end

  def save_links(links)
    links.each do |link|
      attrs = {
        url:         link.url,
        description: link.description,
        shorthand:   link.shorthand,
        tags_json:   link.respond_to?(:tags_json) ? link.tags_json : nil,
        created_at:  link.created_at || Time.now.iso8601
      }
      existing = Hiiro::Link.where(url: link.url).first
      if existing
        existing.update(attrs)
      else
        Hiiro::Link.create(attrs)
      end
    end
    save_yaml_backup
  rescue => e
    warn "Link DB write failed: #{e}"
    save_links_to_yaml(links)
  end

  def save_links_to_yaml(links)
    ensure_links_file
    File.write(@links_file, links.map(&:to_h).to_yaml)
  end

  def save_yaml_backup
    rows = Hiiro::Link.ordered
    ensure_links_file
    File.write(@links_file, rows.map(&:to_h).to_yaml)
  rescue => e
    warn "Link YAML backup failed: #{e}"
  end

  def extract_placeholders(url)
    url.scan(/\{(\w+)\}/).flatten
  end

  def has_placeholders?(url)
    !extract_placeholders(url).empty?
  end

  def prompt_for_placeholder_values(url, link=nil)
    placeholders = extract_placeholders(url)
    return {} if placeholders.empty?

    # Create a YAML template with placeholder names as keys
    template = placeholders.each_with_object({}) { |name, hash| hash[name] = '' }

    tmpfile = Tempfile.new(['link-params-', '.yml'])

    # Add the link as YAML comments if provided
    if link
      link_yaml = link.to_yaml
      link_yaml.each_line do |line|
        tmpfile.puts("# #{line.chomp}")
      end
      tmpfile.puts("#")
      tmpfile.puts("# Fill in placeholder values below:")
      tmpfile.puts("#")
    end

    tmpfile.write(template.to_yaml)
    tmpfile.close

    editor = ENV['EDITOR'] || 'safe_nvim' || 'nvim'
    system(editor, tmpfile.path)

    values = YAML.load_file(tmpfile.path) || {}
    tmpfile.unlink

    values
  end

  def substitute_placeholders(url, values)
    result = url.dup
    values.each do |key, value|
      # Replace spaces with + for URL encoding
      encoded_value = value.to_s.gsub(' ', '+')
      result.gsub!("{#{key}}", encoded_value)
    end
    result
  end

  def find_link_by_ref(ref, links)
    if ref =~ /^\d+$/
      idx = ref.to_i - 1
      return [idx, links[idx]] if idx >= 0 && idx < links.length
    else
      links.each_with_index do |link, idx|
        return [idx, link] if link.shorthand == ref
      end
    end
    [nil, nil]
  end
end

lm = LinkManager.new

Hiiro.run(*ARGV, plugins: [Pins], links_file: lm.links_file) do
  add_subcmd(:add) do |*add_args|
    vals = opts.parse!(add_args)

    if vals.help?
      puts "Usage: h link add [<url>] [description] [--shorthand <alias>] [--tag <tag> ...]"
      puts
      puts opts.help_text
      exit 0
    end

    if vals.args.empty?
      new_links = lm.edit_links

      new_links.each do |link|
        Hiiro::Link.create(
          url: link.url,
          description: link.description,
          shorthand: link.shorthand,
          created_at: link.created_at || Time.now.iso8601
        )
      end
      lm.save_yaml_backup

      count = Hiiro::Link.count
      if new_links.length == 1
        puts "Saved link ##{count}: #{new_links.first.url}"
      else
        puts "Saved #{new_links.length} links"
      end
      exit 0
    end

    url = vals.args.shift
    description = vals.args.join(' ')
    tags = (Array(vals.tag) + Array(vals.tags)).uniq.reject(&:empty?)

    new_link = Hiiro::Link.create(
      url: url,
      description: description,
      shorthand: vals.shorthand,
      created_at: Time.now.iso8601
    )
    Hiiro::Tag.tag!(new_link, *tags) if tags.any?
    lm.save_yaml_backup

    puts "Saved link ##{Hiiro::Link.count}: #{url}"
  end

  add_subcmd(:ls) do |*ls_args|
    links = lm.load_links
    if links.empty?
      puts "No links saved."
    else
      links.each_with_index do |link, idx|
        puts link.display_string(idx)
      end
    end
  end

  add_subcmd(:list) do |*list_args|
    run_subcmd(:ls, *list_args)
  end

  add_subcmd(:search) do |*search_args|
    if search_args.empty?
      puts "Usage: h link search <term> [term...]"
      exit 1
    end

    links = lm.load_links
    matches = links.each_with_index.select { |link, idx| link.matches?(*search_args) }

    if matches.empty?
      puts "No links found matching: #{search_args.join(' ')}"
    else
      matches.each do |link, idx|
        puts link.display_string(idx)
      end
    end
  end

  add_subcmd(:select) do |*select_args|
    links = lm.load_links

    if links.empty?
      STDERR.puts "No links saved."
      exit 1
    end

    lines = lm.load_link_hash(links)

    if select_args.any?
      lines = lm.hash_matches?(lines, *select_args)
    end

    selected = fuzzyfind(lines.keys)

    if !selected.strip.empty?
      link = lines[selected.strip]
      if link
        url = link.url

        if lm.has_placeholders?(url)
          values = lm.prompt_for_placeholder_values(url, link)
          url = lm.substitute_placeholders(url, values)
        end

        puts url
      end
    end
  end

  add_subcmd(:copy) do |*copy_args|
    links = lm.load_links

    if links.empty?
      STDERR.puts "No links saved."
      next
    end

    lines = lm.load_link_hash(links)

    if copy_args.any?
      lines = lm.hash_matches?(lines, *copy_args)
    end

    selected = fuzzyfind(lines.keys)

    if !selected.strip.empty?
      link = lines[selected.strip]
      if link
        url = link.url

        if lm.has_placeholders?(url)
          values = lm.prompt_for_placeholder_values(url, link)
          url = lm.substitute_placeholders(url, values)
        end

        Hiiro::Shell.pipe(url, 'pbcopy')
        puts "Copied URL '#{url}' to clipboard"
      end
    end
  end

  add_subcmd(:editall) do |*editall_args|
    links_before = lm.load_links
    edit_files(lm.links_file)

    begin
      links_after = lm.load_links
    rescue => e
      puts "ERROR: Unable to read updated file...reverting."
      lm.save_links(links_before)
    end
  end

  add_subcmd(:edit) do |*edit_args|
    if edit_args.empty?
      puts "Usage: h link edit <number|shorthand>"
      exit 1
    end

    links = lm.load_links
    idx, link = lm.find_link_by_ref(edit_args.first, links)

    if link.nil?
      puts "Link not found: #{edit_args.first}"
      exit 1
    end

    updated_links = lm.edit_links(link)

    # Replace the original link with the first updated link
    # If multiple links were added, insert them all
    links[idx] = updated_links.first
    if updated_links.length > 1
      links.insert(idx + 1, *updated_links[1..-1])
    end

    lm.save_links(links)

    if updated_links.length == 1
      puts "Updated link ##{idx + 1}"
    else
      puts "Updated link ##{idx + 1} and added #{updated_links.length - 1} more"
    end
  end

  add_subcmd(:rm) do |*rm_args|
    links = lm.load_links

    if links.empty?
      puts "No links saved."
      exit 0
    end

    if rm_args.empty?
      lines = lm.load_link_hash(links)
      selected = fuzzyfind(lines.keys)
      next if selected.nil? || selected.strip.empty?
      link = lines[selected.strip]
      next unless link
      Hiiro::Link.where(url: link.url).delete
      lm.save_yaml_backup
      puts "Removed: #{link.url}"
    else
      rm_args.each do |ref|
        idx, link = lm.find_link_by_ref(ref, links)
        if link.nil?
          # Try URL substring match
          matches = lm.search_links(links, ref)
          if matches.length == 1
            link = matches.first
          elsif matches.length > 1
            puts "Ambiguous: #{matches.length} links match '#{ref}'. Use a number or shorthand."
            matches.each_with_index { |l, i| puts "  #{l.display_string(i)}" }
            next
          else
            puts "Link not found: #{ref}"
            next
          end
        end
        Hiiro::Link.where(url: link.url).delete
        lm.save_yaml_backup
        puts "Removed: #{link.url}"
      end
    end
  end

  add_subcmd(:remove) do |*remove_args|
    run_subcmd(:rm, *remove_args)
  end

  add_subcmd(:open) do |*open_args|
    links = lm.load_links

    if open_args.empty?
      lines = lm.load_link_hash(links)

      exit_code = 1

      if open_args.any?
        lines = lm.hash_matches?(lines, *open_args)
      end

      selected = fuzzyfind(lines.keys)

      if !selected.strip.empty?
        link = lines[selected.strip]
        if link
          url = link.url

          if lm.has_placeholders?(url)
            values = lm.prompt_for_placeholder_values(url, link)
            url = lm.substitute_placeholders(url, values)
          end

          system('open', url)
          exit_code = 0
        end
      end

      exit exit_code
    end

    idx, link = lm.find_link_by_ref(open_args.first, links)

    if link.nil?
      matches = lm.search_links(links, *open_args)

      if matches.count == 1
        link = matches.first
      end
    end

    if link.nil?
      puts "Link not found: #{open_args.first}"
      exit 1
    end

    url = link.url

    if lm.has_placeholders?(url)
      values = lm.prompt_for_placeholder_values(url, link)
      url = lm.substitute_placeholders(url, values)
    end

    system('open', url)
  end

  add_subcmd(:tags) do |*tag_args|
    all_known = Hiiro::Tag.where(taggable_type: 'Link').distinct.pluck(:name).sort

    if tag_args.empty?
      if all_known.empty?
        puts "No tags found."
      else
        all_known.each { |t| puts t }
      end
      next
    end

    # Prefix-match the given args against known tags
    matched_tags = tag_args.flat_map { |arg|
      all_known.select { |t| t.start_with?(arg) }
    }.uniq

    if matched_tags.empty?
      puts "No tags match: #{tag_args.join(', ')}"
      next
    end

    # Batch-load all link tags to avoid N+1
    tagged_ids = Hiiro::Tag.where(taggable_type: 'Link', name: matched_tags).map { |t| t.taggable_id.to_i }.uniq
    links = lm.load_links.select { |link| tagged_ids.include?(link.id) }

    if links.empty?
      puts "No links tagged with: #{matched_tags.join(', ')}"
    else
      links.each_with_index { |link, idx| puts link.display_string(idx) }
    end
  end

  add_subcmd(:paste) do |*paste_args|
    url = `pbpaste`.strip

    if url.empty?
      puts "Clipboard is empty."
      exit 1
    end

    vals = opts.parse!(paste_args)
    description = vals.args.join(' ')
    tags = (Array(vals.tag) + Array(vals.tags)).uniq.reject(&:empty?)

    new_link = Hiiro::Link.create(
      url: url,
      description: description,
      shorthand: vals.shorthand,
      created_at: Time.now.iso8601
    )
    Hiiro::Tag.tag!(new_link, *tags) if tags.any?
    lm.save_yaml_backup

    puts "Saved link ##{Hiiro::Link.count}: #{url}"
  end

  add_subcmd(:path) do |*path_args|
    print lm.links_file
  end
end
