#!/usr/bin/env ruby

require 'hiiro'
require 'shellwords'

Hiiro.run(*ARGV, cwd: Dir.pwd) do
  add_subcmd(:ls)  { |*args| system('git', 'worktree', 'list', *args) }
  add_subcmd(:list)  { |*args| run_subcmd(:ls, *args) }
  add_subcmd(:add)  { |*args| system('git', 'worktree', 'add', *args) }
  add_subcmd(:lock)  { |*args| system('git', 'worktree', 'lock', *args) }
  add_subcmd(:move)  { |*args| system('git', 'worktree', 'move', *args) }
  add_subcmd(:prune)  { |*args| system('git', 'worktree', 'prune', *args) }
  add_subcmd(:remove)  { |*args| system('git', 'worktree', 'remove', *args) }
  add_subcmd(:repair)  { |*args| system('git', 'worktree', 'repair', *args) }
  add_subcmd(:unlock)  { |*args| system('git', 'worktree', 'unlock', *args) }

  add_subcmd(:switch) do |path|
    if path.nil?
      lines = `git worktree list`.strip.split("\n")
      if lines.empty?
        STDERR.puts "No worktrees found"
        next
      end
      map = lines.each_with_object({}) { |line, h| h[line] = line.split.first }
      path = fuzzyfind_from_map(map)
      next unless path
    end

    path = File.expand_path(path)
    session_name = File.basename(path)
    Hiiro::Tmux.open_session(session_name, start_directory: path)
  end

  add_subcmd(:select) do |*args|
    # Get worktree list
    output = `git worktree list`.strip

    if output.empty?
      STDERR.puts "No worktrees found"
      next
    end

    lines = output.split("\n").each_with_object({}) do |line, hash|
      # Format: /path/to/worktree  sha [branch]
      path = line.split.first
      hash[line] = path
    end

    selected = fuzzyfind_from_map(lines)

    if selected
      print selected
    end
  end

  add_subcmd(:size) do |*args|
    output = `git worktree list`.strip

    if output.empty?
      STDERR.puts "No worktrees found"
      next
    end

    output.split("\n").each do |line|
      path, *rest = line.split
      size = `du -sh #{Shellwords.escape(path)} 2>/dev/null`.split.first || "?"
      puts "#{size}\t#{path} #{rest.join(' ')}"
    end
  end

  add_subcmd(:branch) do |*paths|
    if paths.empty?
      # No paths given — print branch for each worktree
      output = `git worktree list`.strip
      if output.empty?
        STDERR.puts "No worktrees found"
        next
      end
      output.split("\n").each do |line|
        parts = line.split
        path = parts[0]
        branch = parts[2]&.gsub(/[\[\]]/, '') || parts[1]
        puts "#{path}\t#{branch}"
      end
    else
      # Resolve each given path and print its branch
      cwd = get_value(:cwd) || Dir.pwd
      paths.each do |path|
        resolved = File.expand_path(path, cwd)
        branch = Dir.chdir(resolved) { `git rev-parse --abbrev-ref HEAD`.strip } rescue nil
        if branch
          puts paths.size > 1 ? "#{resolved}\t#{branch}" : branch
        else
          STDERR.puts "#{resolved}: not a git worktree or error reading branch"
        end
      end
    end
  end

  add_subcmd(:copy) do |*args|
    output = `git worktree list`.strip

    if output.empty?
      STDERR.puts "No worktrees found"
      next
    end

    lines = output.split("\n").each_with_object({}) do |line, hash|
      path = line.split.first
      hash[line] = path
    end

    selected = fuzzyfind_from_map(lines)

    if selected
      Hiiro::Shell.pipe(selected, 'pbcopy')
      puts "Copied worktree path '#{selected}' to clipboard"
    end
  end
end
