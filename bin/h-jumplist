#!/usr/bin/env ruby

require "hiiro"
require "fileutils"

JUMPLIST_DIR = File.join(Dir.home, '.config', 'hiiro', 'jumplist')
MAX_SIZE = 50

FileUtils.mkdir_p(JUMPLIST_DIR)

def client_name
  @client_name ||= `tmux display-message -p '\#{client_name}'`.strip.tr('/', '_')
end

def jumplist_file
  File.join(JUMPLIST_DIR, "#{client_name}-entries")
end

def pos_file
  File.join(JUMPLIST_DIR, "#{client_name}-position")
end

def read_entries
  return [] unless File.exist?(jumplist_file)
  File.readlines(jumplist_file, chomp: true).reject(&:empty?)
end

def write_entries(entries)
  File.write(jumplist_file, entries.join("\n") + "\n")
end

def get_pos
  return 0 unless File.exist?(pos_file)
  File.read(pos_file).strip.to_i
end

def set_pos(n)
  File.write(pos_file, n.to_s)
end

def pane_exists?(pane_id)
  panes = `tmux list-panes -a -F '\#{pane_id}' 2>/dev/null`.strip.split("\n")
  panes.include?(pane_id)
end

def tmux_display(fmt)
  `tmux display-message -p '#{fmt}'`.strip
end

def prune_dead_entries(entries, pos)
  new_entries = []
  new_pos = pos
  entries.each_with_index do |entry, i|
    pane_id = entry.split('|', 2).first
    if pane_exists?(pane_id)
      new_entries << entry
    else
      new_pos -= 1 if i < pos
    end
  end
  new_pos = new_pos.clamp(0, [new_entries.length - 1, 0].max)
  write_entries(new_entries)
  set_pos(new_pos)
  [new_entries, new_pos]
end

Hiiro.run(*ARGV) do
  add_subcmd(:setup) do
    puts <<~SETUP
      # Add the following to your tmux.conf:

      # --- Jumplist hooks (record pane/window/session navigation) ---
      set-hook -g after-select-pane  "run-shell -b 'h jumplist record'"
      set-hook -g after-select-window "run-shell -b 'h jumplist record'"
      set-hook -g client-session-changed "run-shell -b 'h jumplist record'"

      # --- Jumplist keybindings ---
      bind-key -r C-b run-shell "h jumplist back"
      bind-key -r C-f run-shell "h jumplist forward"
    SETUP
  end

  add_subcmd(:clear) do
    pane_id = tmux_display('#{pane_id}')
    window_id = tmux_display('#{window_id}')
    session_name = tmux_display('#{session_name}')
    pane_cmd = tmux_display('#{pane_current_command}')
    timestamp = Time.now.to_i.to_s

    entry = [pane_id, window_id, session_name, timestamp, pane_cmd].join('|')
    write_entries([entry])
    set_pos(0)
    puts "Jumplist cleared."
  end

  add_subcmd(:path) do
    print jumplist_file
  end

  add_subcmd(:ls) do
    entries, pos = prune_dead_entries(read_entries, get_pos)

    if entries.empty?
      puts "Jumplist is empty."
      next
    end

    entries.each_with_index do |entry, i|
      parts = entry.split('|')
      pane_id, window_id, session_name, timestamp, pane_cmd = parts
      time_str = Time.at(timestamp.to_i).strftime('%H:%M:%S')
      marker = i == pos ? " <--" : ""
      puts "%3d) %s | %s | %s | %s | %s%s" % [i, session_name, window_id, pane_id, pane_cmd, time_str, marker]
    end
  end

  add_subcmd(:list) do
    entries, pos = prune_dead_entries(read_entries, get_pos)

    if entries.empty?
      puts "Jumplist is empty."
      next
    end

    entries.each_with_index do |entry, i|
      parts = entry.split('|')
      pane_id, window_id, session_name, timestamp, pane_cmd = parts
      time_str = Time.at(timestamp.to_i).strftime('%H:%M:%S')
      marker = i == pos ? " <--" : ""
      puts "%3d) %s | %s | %s | %s | %s%s" % [i, session_name, window_id, pane_id, pane_cmd, time_str, marker]
    end
  end

  add_subcmd(:record) do
    # Check suppression flag
    suppress = `tmux show-environment TMUX_JUMPLIST_SUPPRESS 2>/dev/null`.strip
    if suppress == "TMUX_JUMPLIST_SUPPRESS=1"
      system('tmux', 'set-environment', '-u', 'TMUX_JUMPLIST_SUPPRESS')
      next
    end

    pane_id = tmux_display('#{pane_id}')
    window_id = tmux_display('#{window_id}')
    session_name = tmux_display('#{session_name}')
    pane_cmd = tmux_display('#{pane_current_command}')
    timestamp = Time.now.to_i.to_s

    entries = read_entries
    pos = get_pos

    # Deduplicate: skip if current position entry is same pane
    current_entry = entries[pos]
    if current_entry
      current_pane = current_entry.split('|', 2).first
      next if current_pane == pane_id
    end

    # If position is not at head, truncate forward history
    if pos > 0 && entries.any?
      entries = entries[pos..]
      set_pos(0)
    elsif pos > 0
      set_pos(0)
    end

    # Prepend new entry (newest first)
    new_entry = [pane_id, window_id, session_name, timestamp, pane_cmd].join('|')
    entries.unshift(new_entry)
    entries = entries.first(MAX_SIZE)
    write_entries(entries)
  end

  add_subcmd(:back) do
    entries, pos = prune_dead_entries(read_entries, get_pos)

    if entries.empty?
      system('tmux', 'display-message', 'Jumplist: empty')
      next
    end

    # If at position 0, record current pane first so forward works
    if pos == 0
      pane_id = tmux_display('#{pane_id}')
      window_id = tmux_display('#{window_id}')
      session_name = tmux_display('#{session_name}')
      pane_cmd = tmux_display('#{pane_current_command}')
      timestamp = Time.now.to_i.to_s

      new_entry = [pane_id, window_id, session_name, timestamp, pane_cmd].join('|')

      # Only prepend if different from current head
      if entries.empty? || entries[0].split('|', 2).first != pane_id
        entries.unshift(new_entry)
        entries = entries.first(MAX_SIZE)
        write_entries(entries)
      end
    end

    new_pos = pos + 1
    if new_pos < entries.length
      parts = entries[new_pos].split('|')
      system('tmux', 'set-environment', 'TMUX_JUMPLIST_SUPPRESS', '1')
      system('tmux', 'switch-client', '-t', parts[2])
      system('tmux', 'select-window', '-t', parts[1])
      system('tmux', 'select-pane', '-t', parts[0])
      set_pos(new_pos)
    else
      system('tmux', 'display-message', 'Jumplist: at oldest entry')
    end
  end

  add_subcmd(:forward) do
    entries, pos = prune_dead_entries(read_entries, get_pos)

    if pos <= 0
      system('tmux', 'display-message', 'Jumplist: at newest entry')
      next
    end

    if entries.empty?
      system('tmux', 'display-message', 'Jumplist: empty')
      next
    end

    new_pos = pos - 1
    parts = entries[new_pos].split('|')
    system('tmux', 'set-environment', 'TMUX_JUMPLIST_SUPPRESS', '1')
    system('tmux', 'switch-client', '-t', parts[2])
    system('tmux', 'select-window', '-t', parts[1])
    system('tmux', 'select-pane', '-t', parts[0])
    set_pos(new_pos)
  end
end
